{%- comment -%}
  EverArt Payment Badges — v4 (+ Klarna FR/DE)
{%- endcomment -%}

{%- assign sid = section.id -%}
{%- assign s   = section.settings -%}

{%- assign epb_market = localization.market.handle | downcase -%}
{%- assign show_klarna = false -%}
{%- if epb_market == 'france' or epb_market == 'germany' -%}
  {%- assign show_klarna = true -%}
{%- endif -%}

<style>
#epb-{{ sid }} {
  background: #121212;
  border-top: 1px solid rgba(255,255,255,.07);
  padding: 20px 0;
}
#epb-{{ sid }} .epb-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
}
#epb-{{ sid }} .epb-label {
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  font-size: 9.5px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
  font-weight: 500;
  white-space: nowrap;
}
#epb-{{ sid }} .epb-icons {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
}
#epb-{{ sid }} .epb-badge {
  background: #1e1e1e;
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 4px;
  padding: 5px 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 32px;
  opacity: .75;
  transition: opacity .2s;
}
#epb-{{ sid }} .epb-badge:hover { opacity: 1; }
#epb-{{ sid }} .epb-badge svg {
  height: 18px;
  width: auto;
  display: block;
}
#epb-{{ sid }} .epb-badge--klarna {
  background: #ffb6c8;
  border-color: #ffb6c8;
  opacity: .9;
}
#epb-{{ sid }} .epb-badge--klarna svg { height: 14px; }
#epb-{{ sid }} .epb-klarna-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 4px;
}
#epb-{{ sid }} .epb-klarna-row__txt {
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
  font-weight: 400;
}
#epb-{{ sid }} .epb-klarna-row__logo svg { height: 13px; width: auto; display: block; }
@media (max-width: 767px) {
  #epb-{{ sid }} { padding: 18px 0; }
  #epb-{{ sid }} .epb-wrap { padding: 0 20px; gap: 12px; }
  #epb-{{ sid }} .epb-label { width: 100%; text-align: center; }
  #epb-{{ sid }} .epb-badge { height: 28px; }
  #epb-{{ sid }} .epb-badge svg { height: 16px; }
}
</style>

<div id="epb-{{ sid }}">
  <div class="epb-wrap">
    {%- if s.label != blank -%}
      <span class="epb-label">{{ s.label }}</span>
    {%- endif -%}
    <div class="epb-icons">
      {%- assign payment_types = 'visa,master,paypal,apple_pay,google_pay,american_express,shopify_pay' | split: ',' -%}
      {%- for type in payment_types -%}
        <div class="epb-badge">{{ type | payment_type_svg_tag }}</div>
      {%- endfor -%}
      {%- if show_klarna -%}
        <div class="epb-badge epb-badge--klarna" aria-label="Klarna">
          <svg viewBox="0 0 84 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M54.23 0h-5.98c0 4.06-1.87 7.8-5.13 10.24L40.5 12l7.74 12H55l-7.35-11.38C51.54 9.37 54.23 4.9 54.23 0Z" fill="#0a0a0a"/>
            <rect x="34.56" width="5.62" height="24" rx="0" fill="#0a0a0a"/>
            <path d="M28.72 24h5.62V0h-5.62v24Z" fill="#0a0a0a"/>
            <path d="M22.5 7.02C21.3 5.7 19.42 4.8 17 4.8c-4.72 0-8.12 3.6-8.12 8.18 0 4.57 3.4 8.16 8.12 8.16 2.42 0 4.3-.9 5.5-2.22V20.8h5.36V5.22H22.5V7.02Zm-5.02 10.36c-2.64 0-4.64-1.98-4.64-4.4s2-4.4 4.64-4.4 4.64 1.98 4.64 4.4-2 4.4-4.64 4.4Z" fill="#0a0a0a"/>
            <path d="M5.7 0H0v24h5.7V0Z" fill="#0a0a0a"/>
            <path d="M74.1 4.8c-2.22 0-4.33.76-5.76 2.8V5.22h-5.36V20.8h5.43V12.4c0-2.56 1.7-3.8 3.76-3.8 2.2 0 3.46 1.3 3.46 3.76v8.44H81v-9.6C81 7.14 78.2 4.8 74.1 4.8Z" fill="#0a0a0a"/>
            <circle cx="81.5" cy="20.5" r="2.5" fill="#0a0a0a"/>
          </svg>
        </div>
      {%- endif -%}
    </div>
    {%- if show_klarna -%}
      <div class="epb-klarna-row">
        <span class="epb-klarna-row__txt">Pay in 3 interest-free installments</span>
        <span class="epb-klarna-row__logo">
          <svg viewBox="0 0 84 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Klarna" role="img">
            <path d="M54.23 0h-5.98c0 4.06-1.87 7.8-5.13 10.24L40.5 12l7.74 12H55l-7.35-11.38C51.54 9.37 54.23 4.9 54.23 0Z" fill="rgba(255,255,255,.45)"/>
            <rect x="34.56" width="5.62" height="24" rx="0" fill="rgba(255,255,255,.45)"/>
            <path d="M28.72 24h5.62V0h-5.62v24Z" fill="rgba(255,255,255,.45)"/>
            <path d="M22.5 7.02C21.3 5.7 19.42 4.8 17 4.8c-4.72 0-8.12 3.6-8.12 8.18 0 4.57 3.4 8.16 8.12 8.16 2.42 0 4.3-.9 5.5-2.22V20.8h5.36V5.22H22.5V7.02Zm-5.02 10.36c-2.64 0-4.64-1.98-4.64-4.4s2-4.4 4.64-4.4 4.64 1.98 4.64 4.4-2 4.4-4.64 4.4Z" fill="rgba(255,255,255,.45)"/>
            <path d="M5.7 0H0v24h5.7V0Z" fill="rgba(255,255,255,.45)"/>
            <path d="M74.1 4.8c-2.22 0-4.33.76-5.76 2.8V5.22h-5.36V20.8h5.43V12.4c0-2.56 1.7-3.8 3.76-3.8 2.2 0 3.46 1.3 3.46 3.76v8.44H81v-9.6C81 7.14 78.2 4.8 74.1 4.8Z" fill="rgba(255,255,255,.45)"/>
            <circle cx="81.5" cy="20.5" r="2.5" fill="rgba(255,255,255,.45)"/>
          </svg>
        </span>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Payment Badges",
  "tag": "section",
  "templates": ["index"],
  "settings": [
    { "type": "text", "id": "label", "label": "Etichetta", "default": "Secure checkout" }
  ],
  "presets": [{ "name": "Payment Badges" }]
}
{% endschema %}