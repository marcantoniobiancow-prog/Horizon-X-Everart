{%- comment -%}
  EverArt Payment Badges — v3
{%- endcomment -%}

{%- assign sid = section.id -%}
{%- assign s   = section.settings -%}

<style>
#epb-{{ sid }} {
  background: #121212;
  border-top: 1px solid rgba(255,255,255,.07);
  padding: 20px 0;
}
#epb-{{ sid }} .epb-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
}
#epb-{{ sid }} .epb-label {
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  font-size: 9.5px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
  font-weight: 500;
  white-space: nowrap;
}
#epb-{{ sid }} .epb-icons {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
}
#epb-{{ sid }} .epb-badge {
  background: #1e1e1e;
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 4px;
  padding: 5px 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 32px;
  opacity: .75;
  transition: opacity .2s;
}
#epb-{{ sid }} .epb-badge:hover { opacity: 1; }
#epb-{{ sid }} .epb-badge svg {
  height: 18px;
  width: auto;
  display: block;
}
@media (max-width: 767px) {
  #epb-{{ sid }} { padding: 18px 0; }
  #epb-{{ sid }} .epb-wrap { padding: 0 20px; gap: 12px; }
  #epb-{{ sid }} .epb-label { width: 100%; text-align: center; }
  #epb-{{ sid }} .epb-badge { height: 28px; }
  #epb-{{ sid }} .epb-badge svg { height: 16px; }
}
</style>

<div id="epb-{{ sid }}">
  <div class="epb-wrap">
    {%- if s.label != blank -%}
      <span class="epb-label">{{ s.label }}</span>
    {%- endif -%}
    <div class="epb-icons">
      {%- assign payment_types = 'visa,master,paypal,apple_pay,google_pay,american_express,shopify_pay' | split: ',' -%}
      {%- for type in payment_types -%}
        <div class="epb-badge">{{ type | payment_type_svg_tag }}</div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Payment Badges",
  "tag": "section",
  "templates": ["index"],
  "settings": [
    { "type": "text", "id": "label", "label": "Etichetta", "default": "Secure checkout" }
  ],
  "presets": [{ "name": "Payment Badges" }]
}
{% endschema %}
