{%- comment -%}
  EverArt — Write a Review
  Form contact nativo Shopify — nessuna app richiesta
  Invia la recensione come email all'admin dello store
{%- endcomment -%}

{%- assign s   = section.settings -%}
{%- assign sid = section.id | replace: '-', '_' -%}

{%- liquid
  assign rating       = product.metafields.reviews.rating.value.rating
  assign scale_max    = product.metafields.reviews.rating.value.scale_max | default: 5
  assign rating_count = product.metafields.reviews.rating_count

  if rating != blank
    assign decimal = rating | modulo: 1
    assign decimal_rating = 0
    if decimal >= 0.3 and decimal <= 0.7
      assign decimal_rating = 0.5
    elsif decimal > 0.7
      assign decimal_rating = 1
    endif
    assign decimal_rounded = decimal_rating | ceil
    assign svg_filled_stars = rating | floor | plus: decimal_rounded
  endif
-%}

<style>
#ewr-{{ sid }} {
  background: var(--bg, #0f0f0f);
  border-top: 1px solid var(--bdr, #2a2a2a);
  padding: 80px 0;
  font-family: var(--sans, 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif);
}
#ewr-{{ sid }} .ewr-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 48px;
}
#ewr-{{ sid }} .ewr-label {
  font-size: 9.5px;
  letter-spacing: .26em;
  text-transform: uppercase;
  color: var(--muted, #888888);
  font-weight: 600;
  display: block;
  margin-bottom: 14px;
}
#ewr-{{ sid }} .ewr-title {
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  letter-spacing: -.02em;
  color: var(--white, #ffffff);
  margin: 0 0 48px;
  line-height: 1.1;
}

/* Aggregate rating */
#ewr-{{ sid }} .ewr-aggregate {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 48px;
  padding-bottom: 48px;
  border-bottom: 1px solid var(--bdr, #2a2a2a);
}
#ewr-{{ sid }} .ewr-stars-display { display: flex; gap: 3px; }
#ewr-{{ sid }} .ewr-star-svg { width: 20px; height: 20px; }
#ewr-{{ sid }} .ewr-star-svg.filled { fill: #c4a030; }
#ewr-{{ sid }} .ewr-star-svg.empty  { fill: rgba(196,160,48,.2); }
#ewr-{{ sid }} .ewr-score {
  font-size: 28px;
  font-weight: 700;
  color: var(--white, #ffffff);
  line-height: 1;
}
#ewr-{{ sid }} .ewr-count {
  font-size: 13px;
  color: var(--muted, #888888);
  letter-spacing: .05em;
}

/* Form */
#ewr-{{ sid }} .ewr-form-wrap { max-width: 680px; }
#ewr-{{ sid }} .ewr-form-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--white, #ffffff);
  margin: 0 0 32px;
  letter-spacing: -.01em;
}

/* Star picker */
#ewr-{{ sid }} .ewr-star-label {
  font-size: 9.5px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--muted, #888888);
  font-weight: 600;
  display: block;
  margin-bottom: 10px;
}
#ewr-{{ sid }} .ewr-star-picker {
  display: flex;
  gap: 6px;
  flex-direction: row-reverse;
  justify-content: flex-end;
  margin-bottom: 28px;
}
#ewr-{{ sid }} .ewr-star-picker input[type="radio"] { display: none; }
#ewr-{{ sid }} .ewr-star-picker label {
  cursor: pointer;
  font-size: 30px;
  color: rgba(196,160,48,.25);
  transition: color .15s ease;
  line-height: 1;
  user-select: none;
}
#ewr-{{ sid }} .ewr-star-picker label:hover,
#ewr-{{ sid }} .ewr-star-picker label:hover ~ label,
#ewr-{{ sid }} .ewr-star-picker input[type="radio"]:checked ~ label {
  color: #c4a030;
}

/* Fields */
#ewr-{{ sid }} .ewr-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 0;
}
#ewr-{{ sid }} .ewr-field { margin-bottom: 16px; }
#ewr-{{ sid }} .ewr-field label {
  font-size: 9.5px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--muted, #888888);
  font-weight: 600;
  display: block;
  margin-bottom: 8px;
}
#ewr-{{ sid }} .ewr-field input,
#ewr-{{ sid }} .ewr-field textarea {
  width: 100%;
  background: var(--surf, #1a1a1a);
  border: 1px solid var(--bdr, #2a2a2a);
  color: var(--white, #ffffff);
  font-family: var(--sans, 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif);
  font-size: 14px;
  padding: 14px 16px;
  border-radius: 2px;
  transition: border-color .15s ease;
  outline: none;
  box-sizing: border-box;
  -webkit-appearance: none;
}
#ewr-{{ sid }} .ewr-field input:focus,
#ewr-{{ sid }} .ewr-field textarea:focus { border-color: #c4a030; }
#ewr-{{ sid }} .ewr-field input::placeholder,
#ewr-{{ sid }} .ewr-field textarea::placeholder { color: var(--dim, #666666); }
#ewr-{{ sid }} .ewr-field textarea { height: 120px; resize: vertical; }

/* Submit */
#ewr-{{ sid }} .ewr-submit {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--white, #ffffff);
  color: var(--bg, #0f0f0f);
  font-family: var(--sans, 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif);
  font-size: 11.5px;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  padding: 16px 32px;
  border: none;
  border-radius: 2px;
  cursor: pointer;
  transition: background .2s ease, color .2s ease;
  margin-top: 8px;
}
#ewr-{{ sid }} .ewr-submit:hover { background: #c4a030; color: var(--bg, #0f0f0f); }
#ewr-{{ sid }} .ewr-submit:disabled { opacity: .5; cursor: not-allowed; }

/* Messages */
#ewr-{{ sid }} .ewr-message {
  padding: 16px 20px;
  border-radius: 2px;
  font-size: 14px;
  margin-bottom: 24px;
  display: none;
}
#ewr-{{ sid }} .ewr-message.is-visible { display: block; }
#ewr-{{ sid }} .ewr-message--success {
  background: rgba(90,154,90,.15);
  border: 1px solid rgba(90,154,90,.4);
  color: #8ecb8e;
}
#ewr-{{ sid }} .ewr-message--error {
  background: rgba(139,26,26,.2);
  border: 1px solid rgba(139,26,26,.5);
  color: #e08080;
}
#ewr-{{ sid }} .ewr-note {
  font-size: 11px;
  color: var(--dim, #666666);
  margin-top: 16px;
  letter-spacing: .03em;
}

@media (max-width: 767px) {
  #ewr-{{ sid }} { padding: 60px 0; }
  #ewr-{{ sid }} .ewr-inner { padding: 0 20px; }
  #ewr-{{ sid }} .ewr-row { grid-template-columns: 1fr; }
}
</style>

<div id="ewr-{{ sid }}">
  <div class="ewr-inner">

    {%- if s.eyebrow != blank -%}
      <span class="ewr-label">{{ s.eyebrow }}</span>
    {%- endif -%}
    <h2 class="ewr-title">{{ s.heading }}</h2>

    {%- if rating != blank -%}
      <div class="ewr-aggregate">
        <svg class="visually-hidden" style="width:0;height:0;" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="ewr-half-{{ sid }}" x1="0" x2="100%" y1="0" y2="0">
              <stop offset="50%" stop-color="#c4a030"></stop>
              <stop offset="50%" stop-color="rgba(196,160,48,.2)"></stop>
            </linearGradient>
            <symbol id="ewr-star-{{ sid }}" viewBox="0 0 32 32">
              <path d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z"/>
            </symbol>
          </defs>
        </svg>
        <div class="ewr-stars-display" aria-label="{{ rating | round: 1 }}/{{ scale_max }}">
          {%- for star in (1..scale_max) -%}
            <svg class="ewr-star-svg {% if star <= svg_filled_stars %}filled{% else %}empty{% endif %}" viewBox="0 0 32 32" role="presentation">
              <use xlink:href="#ewr-star-{{ sid }}"{% if decimal_rating == 0.5 and star == svg_filled_stars %} fill="url(#ewr-half-{{ sid }})"{% endif %}></use>
            </svg>
          {%- endfor -%}
        </div>
        <span class="ewr-score">{{ rating | round: 1 }}</span>
        <span class="ewr-count">{{ rating_count }} {{ 'content.reviews' | t }}</span>
      </div>
    {%- endif -%}

    <div class="ewr-form-wrap">
      <p class="ewr-form-title">{{ s.form_heading }}</p>

      <div id="ewr-success-{{ sid }}" class="ewr-message ewr-message--success" role="alert">
        {{ s.success_msg }}
      </div>
      <div id="ewr-error-{{ sid }}" class="ewr-message ewr-message--error" role="alert">
        {{ s.error_msg }}
      </div>

      <form id="ewr-form-{{ sid }}" novalidate>
        <input type="hidden" name="contact[product]" value="{{ product.title | escape }}">
        <input type="hidden" name="contact[product_url]" value="{{ shop.url }}{{ product.url }}">
        <input type="hidden" id="ewr-rating-val-{{ sid }}" name="contact[rating]" value="">

        <span class="ewr-star-label">{{ s.rating_label }}</span>
        <div class="ewr-star-picker" role="group" aria-label="{{ s.rating_label }}">
          {%- for i in (5..1) -%}
            <input type="radio" name="_rating_display" id="ewr-star-{{ sid }}-{{ i }}" value="{{ i }}">
            <label for="ewr-star-{{ sid }}-{{ i }}" aria-label="{{ i }} stelle">★</label>
          {%- endfor -%}
        </div>

        <div class="ewr-field">
          <label for="ewr-rtitle-{{ sid }}">{{ s.title_label }}</label>
          <input type="text" id="ewr-rtitle-{{ sid }}" name="contact[review_title]" placeholder="{{ s.title_placeholder }}">
        </div>

        <div class="ewr-field">
          <label for="ewr-body-{{ sid }}">{{ s.body_label }}</label>
          <textarea id="ewr-body-{{ sid }}" name="contact[body]" placeholder="{{ s.body_placeholder }}" required></textarea>
        </div>

        <div class="ewr-row">
          <div class="ewr-field">
            <label for="ewr-author-{{ sid }}">{{ s.author_label }}</label>
            <input type="text" id="ewr-author-{{ sid }}" name="contact[name]" placeholder="{{ s.author_placeholder }}" required>
          </div>
          <div class="ewr-field">
            <label for="ewr-email-{{ sid }}">{{ s.email_label }}</label>
            <input type="email" id="ewr-email-{{ sid }}" name="contact[email]" placeholder="{{ s.email_placeholder }}" required>
          </div>
        </div>

        <button type="submit" class="ewr-submit" id="ewr-btn-{{ sid }}">
          {{ s.btn_label }}
        </button>

        <p class="ewr-note">{{ s.note }}</p>
      </form>
    </div>

  </div>
</div>

<script>
(function() {
  var wrap  = document.getElementById('ewr-{{ sid }}');
  if (!wrap) return;

  var form    = document.getElementById('ewr-form-{{ sid }}');
  var btn     = document.getElementById('ewr-btn-{{ sid }}');
  var ratingHidden = document.getElementById('ewr-rating-val-{{ sid }}');
  var msgOk   = document.getElementById('ewr-success-{{ sid }}');
  var msgErr  = document.getElementById('ewr-error-{{ sid }}');

  /* Sync hidden rating value from radio group */
  wrap.querySelectorAll('input[name="_rating_display"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
      ratingHidden.value = this.value;
    });
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    msgOk.classList.remove('is-visible');
    msgErr.classList.remove('is-visible');

    var email = form.querySelector('[name="contact[email]"]').value.trim();
    var name  = form.querySelector('[name="contact[name]"]').value.trim();
    var body  = form.querySelector('[name="contact[body]"]').value.trim();
    var rating = ratingHidden.value;

    if (!email || !name || !body) {
      msgErr.classList.add('is-visible');
      return;
    }

    /* Prepend rating + product to body for email readability */
    var productTitle = form.querySelector('[name="contact[product]"]').value;
    var reviewTitle  = form.querySelector('[name="contact[review_title]"]').value.trim();
    var fullBody = '★ Rating: ' + (rating || 'n/a') + '/5\n';
    if (reviewTitle) fullBody += 'Title: ' + reviewTitle + '\n';
    fullBody += '\n' + body + '\n\n— Product: ' + productTitle;
    form.querySelector('[name="contact[body]"]').value = fullBody;

    btn.disabled = true;
    btn.textContent = '...';

    var data = new FormData(form);
    data.append('form_type', 'contact');
    data.append('utf8', '✓');

    fetch('/contact', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: data
    })
    .then(function(r) {
      if (r.ok || r.status === 200) {
        form.reset();
        ratingHidden.value = '';
        msgOk.classList.add('is-visible');
        form.style.display = 'none';
      } else {
        throw new Error('submit failed');
      }
    })
    .catch(function() {
      form.querySelector('[name="contact[body]"]').value = body;
      msgErr.classList.add('is-visible');
      btn.disabled = false;
      btn.textContent = '{{ s.btn_label | escape }}';
    });
  });
})();
</script>

{% schema %}
{
  "name": "EA — Write Review",
  "tag": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verified Collectors" },
    { "type": "text", "id": "heading", "label": "Titolo sezione", "default": "Share your experience." },
    { "type": "text", "id": "form_heading", "label": "Sottotitolo form", "default": "Write a review" },
    { "type": "text", "id": "rating_label", "label": "Label stelle", "default": "Your Rating" },
    { "type": "text", "id": "title_label", "label": "Label titolo recensione", "default": "Review Title" },
    { "type": "text", "id": "title_placeholder", "label": "Placeholder titolo", "default": "Give your review a title" },
    { "type": "text", "id": "body_label", "label": "Label testo", "default": "Your Review" },
    { "type": "text", "id": "body_placeholder", "label": "Placeholder testo", "default": "Tell us about your experience with this piece" },
    { "type": "text", "id": "author_label", "label": "Label nome", "default": "Name" },
    { "type": "text", "id": "author_placeholder", "label": "Placeholder nome", "default": "Your name" },
    { "type": "text", "id": "email_label", "label": "Label email", "default": "Email" },
    { "type": "text", "id": "email_placeholder", "label": "Placeholder email", "default": "your@email.com" },
    { "type": "text", "id": "btn_label", "label": "Testo bottone", "default": "Submit Review" },
    { "type": "text", "id": "success_msg", "label": "Messaggio successo", "default": "Thank you — your review has been submitted." },
    { "type": "text", "id": "error_msg", "label": "Messaggio errore", "default": "Please fill in all required fields." },
    { "type": "text", "id": "note", "label": "Nota sotto form", "default": "Reviews are moderated and published within 48 hours." }
  ],
  "presets": [{ "name": "EA — Write Review" }]
}
{% endschema %}
