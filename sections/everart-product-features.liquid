{%- comment -%}
  EverArt Product Features — v2
  Strip orizzontale full-width: N card verticali (immagine + testo) in una riga
  Blocks: feature_card
{%- endcomment -%}

{%- assign s   = section.settings -%}
{%- assign sid = section.id -%}

{%- if section.blocks.size > 0 -%}
<style>
#epf-{{ sid }} {
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  background: #0a0a0a;
  border-top: 1px solid rgba(255,255,255,.08);
}
#epf-{{ sid }} .epf-strip {
  display: grid;
  grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
  gap: 0;
}
#epf-{{ sid }} .epf-card {
  background: #121212;
  border-right: 1px solid rgba(255,255,255,.08);
  display: flex;
  flex-direction: column;
}
#epf-{{ sid }} .epf-card:last-child {
  border-right: none;
}
#epf-{{ sid }} .epf-img {
  aspect-ratio: 1;
  overflow: hidden;
  background: #1a1a1a;
  flex-shrink: 0;
}
#epf-{{ sid }} .epf-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .4s ease;
}
#epf-{{ sid }} .epf-card:hover .epf-img img {
  transform: scale(1.03);
}
#epf-{{ sid }} .epf-body {
  padding: 32px 36px 40px;
  display: flex;
  flex-direction: column;
  flex: 1;
  border-top: 1px solid rgba(255,255,255,.08);
}
#epf-{{ sid }} .epf-tag {
  font-size: 9px;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: #a52020;
  margin-bottom: 12px;
  display: block;
  font-weight: 700;
}
#epf-{{ sid }} .epf-title {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 10px;
  line-height: 1.15;
  letter-spacing: -.01em;
  color: #ffffff;
}
#epf-{{ sid }} .epf-desc {
  font-size: 13px;
  color: rgba(255,255,255,.5);
  line-height: 1.75;
  font-weight: 400;
  margin: 0;
}
@media (max-width: 1023px) {
  #epf-{{ sid }} .epf-strip {
    grid-template-columns: repeat(2, 1fr);
  }
  #epf-{{ sid }} .epf-card:nth-child(2) { border-right: none; }
  #epf-{{ sid }} .epf-card:nth-child(n+3) { border-top: 1px solid rgba(255,255,255,.08); }
}
@media (max-width: 599px) {
  #epf-{{ sid }} .epf-strip { grid-template-columns: 1fr; }
  #epf-{{ sid }} .epf-card { border-right: none; border-top: 1px solid rgba(255,255,255,.08); }
  #epf-{{ sid }} .epf-card:first-child { border-top: none; }
  #epf-{{ sid }} .epf-body { padding: 24px 20px 28px; }
}
@media (prefers-reduced-motion: reduce) {
  #epf-{{ sid }} .epf-img img { transition: none; }
}
</style>

<div id="epf-{{ sid }}">
  <div class="epf-strip">
    {%- for block in section.blocks -%}
      <div class="epf-card" {{ block.shopify_attributes }}>
        <div class="epf-img">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}"
                 alt="{{ block.settings.image.alt | default: block.settings.title }}"
                 width="600"
                 loading="lazy">
          {%- endif -%}
        </div>
        <div class="epf-body">
          {%- liquid
            assign ft_tag   = block.settings.tag
            assign ft_title = block.settings.title
            assign ft_desc  = block.settings.description
            if ft_title contains 'Heads' or ft_title contains 'Teste'
              assign ft_tag   = 'everart.features.exclusive' | t | default: ft_tag
              assign ft_title = 'everart.features.heads_title' | t | default: ft_title
              assign ft_desc  = 'everart.features.heads_desc' | t | default: ft_desc
            elsif ft_title contains 'Necronomicon'
              assign ft_tag   = 'everart.features.included' | t | default: ft_tag
              assign ft_title = 'everart.features.necronomicon_title' | t | default: ft_title
              assign ft_desc  = 'everart.features.necronomicon_desc' | t | default: ft_desc
            elsif ft_title contains 'Print' or ft_title contains 'Stampa'
              assign ft_tag   = 'everart.features.included' | t | default: ft_tag
              assign ft_title = 'everart.features.artprint_title' | t | default: ft_title
              assign ft_desc  = 'everart.features.artprint_desc' | t | default: ft_desc
            elsif ft_title contains 'Certificate' or ft_title contains 'Certificato'
              assign ft_tag   = 'everart.features.your_number' | t | default: ft_tag
              assign ft_title = 'everart.features.certificate_title' | t | default: ft_title
              assign ft_desc  = 'everart.features.certificate_desc' | t | default: ft_desc
            endif
          -%}
          {%- if ft_tag != blank -%}
            <span class="epf-tag">{{ ft_tag }}</span>
          {%- endif -%}
          {%- if ft_title != blank -%}
            <div class="epf-title">{{ ft_title }}</div>
          {%- endif -%}
          {%- if ft_desc != blank -%}
            <p class="epf-desc">{{ ft_desc }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Prodotto — Features",
  "tag": "section",
  "templates": ["product"],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature card",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image",       "label": "Immagine" },
        { "type": "text",         "id": "tag",         "label": "Tag (rosso, es. Exclusive Feature)" },
        { "type": "text",         "id": "title",       "label": "Titolo" },
        { "type": "textarea",     "id": "description", "label": "Descrizione" }
      ]
    }
  ],
  "settings": [],
  "presets": [{ "name": "Prodotto — Features" }]
}
{% endschema %}
