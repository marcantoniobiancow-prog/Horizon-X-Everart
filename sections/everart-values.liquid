{%- comment -%}
  EverArt Values — v1
  3-col grid con numero, titolo e descrizione.
  Design fedele all'HTML preview (everart-site-preview.html).
{%- endcomment -%}

{%- liquid
  assign s   = section.settings
  assign sid = section.id
-%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');

#ea-values-{{ sid }} {
  background: #0a0a0a;
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  padding: 80px 0 0;
  border-top: 1px solid #2a2a2a;
}

#ea-values-{{ sid }} .eav-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: #2a2a2a;
  width: 100%;
}

#ea-values-{{ sid }} .eav-item {
  background: #212121;
  padding: 48px 40px;
}

#ea-values-{{ sid }} .eav-num {
  font-size: 48px;
  font-weight: 700;
  color: #2c2c2c;
  letter-spacing: -.03em;
  display: block;
  margin-bottom: 24px;
  line-height: 1;
}

#ea-values-{{ sid }} .eav-title {
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: #ffffff;
  margin-bottom: 12px;
  font-weight: 700;
}

#ea-values-{{ sid }} .eav-desc {
  font-size: 13px;
  color: #888888;
  line-height: 1.75;
  font-weight: 400;
  margin: 0;
}

@media (max-width: 767px) {
  #ea-values-{{ sid }} .eav-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<div id="ea-values-{{ sid }}">
  <div class="eav-grid">

    {%- for i in (1..3) -%}
      {%- liquid
        case i
          when 1
            assign title = s.title_1
            assign desc  = s.desc_1
            assign num   = '01'
          when 2
            assign title = s.title_2
            assign desc  = s.desc_2
            assign num   = '02'
          when 3
            assign title = s.title_3
            assign desc  = s.desc_3
            assign num   = '03'
        endcase
      -%}
      {%- if title != blank -%}
        <div class="eav-item">
          <span class="eav-num">{{ num }}</span>
          <div class="eav-title">{{ title }}</div>
          {%- if desc != blank -%}
            <p class="eav-desc">{{ desc }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "EverArt Values",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Punto 01"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Titolo",
      "default": "Strong Packaging"
    },
    {
      "type": "textarea",
      "id": "desc_1",
      "label": "Descrizione",
      "default": "Rigid box with custom-shaped protective interior. The unboxing is part of the experience — not an afterthought."
    },
    {
      "type": "header",
      "content": "Punto 02"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Titolo",
      "default": "Hand Painted"
    },
    {
      "type": "textarea",
      "id": "desc_2",
      "label": "Descrizione",
      "default": "Each piece painted by hand. Every shade, every transition applied with intention. No two are identical."
    },
    {
      "type": "header",
      "content": "Punto 03"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Titolo",
      "default": "Narrative Meta-Story"
    },
    {
      "type": "textarea",
      "id": "desc_3",
      "label": "Descrizione",
      "default": "Not a collectible object. A genuine story — told through resin, paint, and the weight of craft."
    }
  ]
}
{% endschema %}
