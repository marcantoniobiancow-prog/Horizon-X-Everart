{%- comment -%}
  EverArt Product Main — v3
  Usa {% stylesheet %} + CSS nesting (nessun selettore ripetuto).
  Variabili colore: Shopify custom properties dove disponibili, altrimenti
  variabili locali definite una sola volta in :root/.epm-wrapper.
  Blocks: bundle_item · accordion_item · payment_option
{%- endcomment -%}

{%- assign s       = section.settings -%}
{%- assign sid     = section.id -%}
{%- assign p       = product -%}
{%- assign variant = p.selected_or_first_available_variant -%}
{%- assign media   = p.media -%}

{%- liquid
  assign col_title = s.collection_label
  if col_title == blank and p.collections.size > 0
    assign col_title = p.collections[0].title
  endif

  assign bundle_items    = section.blocks | where: 'type', 'bundle_item'
  assign accordion_items = section.blocks | where: 'type', 'accordion_item'
  assign pay_opts        = section.blocks | where: 'type', 'payment_option'
-%}

{% stylesheet %}

/* ─────────────────────────────────────────
   Variabili locali Everart (definite una sola volta)
   ───────────────────────────────────────── */
.epm-wrapper {
  --epm-bg:      #0a0a0a;
  --epm-surf:    #121212;
  --epm-bdr:     rgb(var(--color-foreground-rgb, 255 255 255) / 0.1);
  --epm-red:     #8b1a1a;
  --epm-red2:    #a52020;
  --epm-fg:      var(--color-foreground, #ffffff);
  --epm-muted:   rgb(var(--color-foreground-rgb, 255 255 255) / 0.55);
  --epm-dim:     rgb(var(--color-foreground-rgb, 255 255 255) / 0.4);
  --epm-green:   #5a9a5a;
  --epm-font:    var(--font-body-family, 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif);

  background: var(--epm-bg);
  color: var(--epm-fg);
  font-family: var(--epm-font);

  /* ── Breadcrumb ── */
  .epm-breadcrumb {
    font-size: 10.5px;
    letter-spacing: .08em;
    color: var(--epm-muted);
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 18px 48px;
    border-bottom: 1px solid var(--epm-bdr);
    background: var(--epm-surf);

    a {
      color: var(--epm-muted);
      text-decoration: none;
      transition: color .2s;

      &:hover { color: var(--epm-fg); }
    }

    .epm-bc-current { color: rgb(var(--color-foreground-rgb, 255 255 255) / 0.8); }
  }

  /* ── Page grid ── */
  .epm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    max-width: 1600px;
    margin: 0 auto;
  }

  /* ── Gallery ── */
  .epm-gallery {
    border-right: 1px solid var(--epm-bdr);

    .epm-img-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
      background: var(--epm-bdr);

      &.single { grid-template-columns: 1fr; }
    }

    .epm-img-cell {
      aspect-ratio: 1;
      overflow: hidden;
      background: #212121;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
    }
  }

  /* ── Info panel (sticky) ── */
  .epm-info {
    padding: 48px 56px;
    position: sticky;
    top: 0;
    max-height: 100vh;
    overflow-y: auto;
    scrollbar-width: none;

    &::-webkit-scrollbar { display: none; }
  }

  /* ── Tag / title / sub ── */
  .epm-tag {
    font-size: 9.5px;
    letter-spacing: .26em;
    text-transform: uppercase;
    color: var(--epm-muted);
    display: block;
    margin-bottom: 12px;
    font-weight: 500;
  }

  .epm-title {
    font-size: clamp(36px, 4vw, 52px);
    line-height: 1;
    font-weight: 800;
    letter-spacing: -.03em;
    margin: 0 0 4px;
    color: var(--epm-fg);
  }

  .epm-sub {
    font-size: 13px;
    color: var(--epm-muted);
    font-style: italic;
    margin: 0 0 36px;
    font-weight: 400;
    letter-spacing: .04em;
  }

  /* ── Edition counter ── */
  .epm-edition {
    margin-bottom: 32px;

    .epm-edition-label {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }

    .epm-edition-lbl {
      font-size: 9.5px;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--epm-muted);
      font-weight: 600;
    }

    .epm-edition-count {
      font-size: 10px;
      color: var(--epm-muted);
      font-weight: 500;

      strong { color: var(--epm-fg); }
    }

    .epm-edition-track {
      height: 3px;
      background: var(--epm-bdr);
      position: relative;
      overflow: hidden;
    }

    .epm-edition-fill {
      position: absolute;
      left: 0; top: 0;
      height: 100%;
      background: var(--epm-fg);
      transition: width .6s ease;
    }
  }

  /* ── Bundle box ── */
  .epm-bundle {
    background: var(--epm-surf);
    padding: 0;
    margin-bottom: 24px;

    .epm-bundle-acc-h {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      padding: 16px 24px;
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--epm-font);
      font-size: 9.5px;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--epm-muted);
      font-weight: 600;
      text-align: left;
      transition: color .2s;

      &:hover { color: var(--epm-fg); }
    }

    .epm-bundle-acc-arrow {
      font-size: 16px;
      font-weight: 300;
      color: var(--epm-muted);
      transition: transform .2s;
      flex-shrink: 0;
      line-height: 1;

      &.open { transform: rotate(180deg); }
    }

    .epm-bundle-acc-b {
      display: none;
      padding: 0 24px 4px;

      &.open { display: block; }
    }

    .epm-bundle-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid var(--epm-bdr);
      font-size: 13px;

      &:last-of-type { border: none; }
    }

    .epm-bundle-item { color: rgb(var(--color-foreground-rgb, 255 255 255) / 0.8); font-weight: 400; }
    .epm-bundle-price { color: var(--epm-muted); font-weight: 500; font-size: 14px; }

    .epm-bundle-footer {
      padding: 0 24px 20px;
      border-top: 1px solid var(--epm-bdr);
    }

    .epm-bundle-discount {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0 0;
      font-size: 13px;

      .epm-bundle-item { color: #c44; }
      .epm-bundle-price { color: #c44; }
    }

    .epm-bundle-total {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 14px 0 0;
      margin-top: 4px;
      border-top: 1px solid var(--epm-bdr);

      .epm-bundle-total-lbl {
        font-size: 10px;
        letter-spacing: .2em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--epm-fg);
      }

      .epm-bundle-total-price {
        font-size: 36px;
        font-weight: 800;
        color: var(--epm-fg);
        letter-spacing: -.03em;
      }
    }

    .epm-bundle-save {
      font-size: 10px;
      color: var(--epm-green);
      margin-top: 6px;
      text-align: right;
      letter-spacing: .05em;
      font-weight: 500;
    }
  }

  /* ── Varianti ── */
  .epm-variants {
    margin-bottom: 20px;

    .epm-variant-label {
      font-size: 9.5px;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--epm-muted);
      margin-bottom: 10px;
      font-weight: 600;
      display: block;
    }

    .epm-variant-btns {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .epm-variant-btn {
      background: var(--epm-bg);
      border: 1px solid var(--epm-bdr);
      color: var(--epm-muted);
      padding: 10px 18px;
      font-size: 12px;
      font-family: var(--epm-font);
      font-weight: 500;
      cursor: pointer;
      transition: border-color .2s, color .2s;
      letter-spacing: .04em;

      &:hover,
      &.sel {
        border-color: var(--epm-fg);
        color: var(--epm-fg);
      }

      &.unavail {
        opacity: 0.35;
        cursor: default;
        text-decoration: line-through;
      }
    }
  }

  /* ── Quantità ── */
  .epm-qty-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;

    .epm-qty-lbl {
      font-size: 9.5px;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--epm-muted);
      font-weight: 600;
    }

    .epm-qty-ctrl {
      display: flex;
      align-items: center;
      border: 1px solid var(--epm-bdr);
    }

    .epm-qty-btn {
      background: none;
      border: none;
      color: var(--epm-muted);
      width: 36px;
      height: 36px;
      font-size: 18px;
      cursor: pointer;
      font-family: var(--epm-font);
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color .2s;

      &:hover { color: var(--epm-fg); }
    }

    .epm-qty-input {
      background: none;
      border: none;
      border-left: 1px solid var(--epm-bdr);
      border-right: 1px solid var(--epm-bdr);
      color: var(--epm-fg);
      width: 48px;
      height: 36px;
      text-align: center;
      font-size: 14px;
      font-family: var(--epm-font);
      font-weight: 600;
      outline: none;
      -moz-appearance: textfield;

      &::-webkit-outer-spin-button,
      &::-webkit-inner-spin-button { -webkit-appearance: none; }
    }
  }

  /* ── Payment options ── */
  .epm-pay-label {
    font-size: 9.5px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--epm-muted);
    margin-bottom: 10px;
    font-weight: 600;
    display: block;
  }

  .epm-pay-opts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-bottom: 16px;

    .epm-pay-opt {
      border: 1px solid var(--epm-bdr);
      padding: 16px 18px;
      cursor: pointer;
      transition: border-color .2s;
      background: var(--epm-bg);

      &.sel { border-color: var(--epm-fg); }
    }

    .epm-po-lbl {
      font-size: 9px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--epm-muted);
      margin-bottom: 4px;
      font-weight: 600;
    }

    .epm-po-amount {
      font-size: 22px;
      font-weight: 700;
      color: var(--epm-fg);
      letter-spacing: -.02em;
    }

    .epm-po-note {
      font-size: 10px;
      color: var(--epm-muted);
      margin-top: 2px;
      font-weight: 400;
    }
  }

  /* ── ATC ── */
  .epm-atc-btn {
    width: 100%;
    background: var(--epm-red);
    color: #ffffff;
    padding: 18px;
    font-size: 11px;
    letter-spacing: .26em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    margin-bottom: 10px;
    transition: background .2s;
    border: none;
    font-family: var(--epm-font);

    &:hover { background: var(--epm-red2); }
    &:disabled { opacity: .45; cursor: default; background: var(--epm-red); }
  }

  .epm-atc-note {
    font-size: 11px;
    color: var(--epm-muted);
    text-align: center;
    letter-spacing: .05em;
    font-weight: 400;
  }

  /* ── Accordion ── */
  .epm-accordion {
    border-top: 1px solid var(--epm-bdr);
    margin-top: 32px;

    .epm-acc-item { border-bottom: 1px solid var(--epm-bdr); }

    .epm-acc-h {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      cursor: pointer;
      font-size: 11px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: rgb(var(--color-foreground-rgb, 255 255 255) / 0.8);
      font-weight: 600;
      user-select: none;
      background: none;
      border: none;
      width: 100%;
      text-align: left;
      font-family: var(--epm-font);

      &:hover { color: var(--epm-fg); }
    }

    .epm-acc-arrow {
      color: var(--epm-muted);
      font-size: 16px;
      transition: transform .2s;
      line-height: 1;
      font-weight: 300;
      flex-shrink: 0;

      &.open { transform: rotate(180deg); }
    }

    .epm-acc-b {
      padding: 0 0 20px;
      font-size: 13px;
      color: var(--epm-muted);
      line-height: 1.8;
      display: none;
      font-weight: 400;

      &.open { display: block; }

      p { margin-bottom: 12px; }
    }

    .epm-spec-t {
      width: 100%;
      border-collapse: collapse;

      tr { border-bottom: 1px solid var(--epm-bdr); }

      td {
        padding: 9px 0;
        font-size: 13px;

        &:first-child { color: var(--epm-muted); width: 44%; font-weight: 400; }
        &:last-child  { color: var(--epm-fg); font-weight: 500; }
      }
    }
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .epm-breadcrumb { padding: 14px 20px; }
    .epm-grid { grid-template-columns: 1fr; }
    .epm-gallery {
      border-right: none;
      position: relative;
    }
    .epm-img-grid {
      display: flex !important;
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      gap: 0 !important;
      background: transparent !important;
    }
    .epm-img-grid::-webkit-scrollbar { display: none; }
    .epm-img-cell {
      flex: 0 0 100%;
      width: 100%;
      aspect-ratio: 1 !important;
      scroll-snap-align: start;
    }
    .epm-dots {
      display: flex !important;
    }
    .epm-info { padding: 32px 20px 56px; position: static; max-height: none; overflow-y: visible; }
    .epm-pay-opts { grid-template-columns: 1fr; }
  }

  /* ── Dots (nascosti su desktop) ── */
  .epm-dots {
    display: none;
    justify-content: center;
    align-items: center;
    gap: 6px;
    padding: 14px 0;
    background: var(--epm-bg);

    .epm-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(255,255,255,.2);
      transition: background .2s, transform .2s;
      flex-shrink: 0;

      &.active {
        background: #ffffff;
        transform: scale(1.25);
      }
    }
  }
}

/* ── Sticky CTA (fuori dal wrapper, fixed globale) ── */
.epm-sticky {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(10, 10, 10, .97);
  backdrop-filter: blur(12px);
  border-top: 1px solid rgb(255 255 255 / 0.1);
  padding: 14px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 300;
  transform: translateY(100%);
  transition: transform .3s ease;
  font-family: var(--font-body-family, 'Instrument Sans', sans-serif);
  color: #ffffff;

  &.vis { transform: translateY(0); }

  .sc-name  { font-size: 15px; font-weight: 700; letter-spacing: -.01em; }
  .sc-price { font-size: 28px; font-weight: 800; letter-spacing: -.02em; }
  .sc-ed    { font-size: 10px; color: rgb(255 255 255 / 0.55); letter-spacing: .06em; margin-top: 2px; }

  .sc-btn {
    background: #8b1a1a;
    color: #ffffff;
    border: none;
    padding: 14px 32px;
    font-size: 10px;
    letter-spacing: .24em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    font-family: var(--font-body-family, 'Instrument Sans', sans-serif);
    transition: background .2s;
    white-space: nowrap;

    &:hover { background: #a52020; }
  }

  @media (max-width: 767px) {
    padding: 12px 20px;
    .sc-price { font-size: 20px; }
  }
}

{% endstylesheet %}

<div class="epm-wrapper">

  {%- comment -%} Breadcrumb {%- endcomment -%}
  <div class="epm-breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    {%- if p.collections.size > 0 -%}
      <a href="{{ p.collections[0].url }}">{{ p.collections[0].title }}</a>
      <span>/</span>
    {%- endif -%}
    <span class="epm-bc-current">{{ p.title }}</span>
  </div>

  <div class="epm-grid">

    {%- comment -%} ── GALLERY ── {%- endcomment -%}
    {%- assign images = media | where: 'media_type', 'image' -%}
    <div class="epm-gallery">
      <div class="epm-img-grid {% if images.size <= 1 %}single{% endif %}"
           id="epm-gallery-{{ sid }}">
        {%- for m in images -%}
          <div class="epm-img-cell">
            <img src="{{ m | image_url: width: 900 }}"
                 alt="{{ m.alt | default: p.title }}"
                 width="900"
                 loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
          </div>
        {%- endfor -%}
      </div>
      {%- if images.size > 1 -%}
        <div class="epm-dots" id="epm-dots-{{ sid }}">
          {%- for m in images -%}
            <div class="epm-dot {% if forloop.first %}active{% endif %}"
                 data-index="{{ forloop.index0 }}"></div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── INFO PANEL ── {%- endcomment -%}
    <div class="epm-info">

      {%- if col_title != blank -%}
        <span class="epm-tag">{{ col_title }}</span>
      {%- endif -%}
      <h1 class="epm-title">{{ p.title }}</h1>
      {%- assign sub = s.subtitle | default: p.type -%}
      {%- if sub != blank -%}
        <div class="epm-sub">{{ sub }}</div>
      {%- endif -%}

      {%- comment -%} Edition counter {%- endcomment -%}
      {%- if s.show_edition and s.edition_total > 0 -%}
        {%- assign pct = s.edition_claimed | times: 100.0 | divided_by: s.edition_total | round -%}
        <div class="epm-edition">
          <div class="epm-edition-label">
            <span class="epm-edition-lbl">Edition Progress</span>
            <span class="epm-edition-count">
              <strong>{{ s.edition_claimed }}</strong> / {{ s.edition_total }} claimed
              {%- if s.edition_ships != blank %} · {{ s.edition_ships }}{%- endif -%}
            </span>
          </div>
          <div class="epm-edition-track">
            <div class="epm-edition-fill" style="width:{{ pct }}%"></div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Bundle box {%- endcomment -%}
      {%- if bundle_items.size > 0 -%}
        <div class="epm-bundle">

          {%- comment -%} Accordion header {%- endcomment -%}
          <button class="epm-bundle-acc-h"
                  onclick="epmBundleAcc_{{ sid }}(this)"
                  aria-expanded="false">
            {{ s.bundle_title | default: "What's Included" }}
            <span class="epm-bundle-acc-arrow">&#8964;</span>
          </button>

          {%- comment -%} Accordion body — voci bundle + valore totale {%- endcomment -%}
          <div class="epm-bundle-acc-b" id="epm-bundle-body-{{ sid }}">
            {%- for block in bundle_items -%}
              <div class="epm-bundle-line" {{ block.shopify_attributes }}>
                <span class="epm-bundle-item">{{ block.settings.item }}</span>
                <span class="epm-bundle-price">{{ block.settings.price }}</span>
              </div>
            {%- endfor -%}
            {%- if s.bundle_original_price != blank -%}
              <div class="epm-bundle-line" style="border-top:1px solid var(--epm-bdr);margin-top:4px;padding-top:12px">
                <span class="epm-bundle-item" style="color:var(--epm-muted)">Bundle value</span>
                <span class="epm-bundle-price" style="text-decoration:line-through">{{ s.bundle_original_price }}</span>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Sempre visibile: sconto + prezzo finale {%- endcomment -%}
          <div class="epm-bundle-footer">
            {%- if s.bundle_discount_label != blank -%}
              <div class="epm-bundle-discount">
                <span class="epm-bundle-item">{{ s.bundle_discount_label }}</span>
                <span class="epm-bundle-price">{{ s.bundle_discount_amount }}</span>
              </div>
            {%- endif -%}
            <div class="epm-bundle-total">
              <span class="epm-bundle-total-lbl">{{ s.bundle_total_label | default: 'Your price today' }}</span>
              <span class="epm-bundle-total-price">{{ variant.price | money }}</span>
            </div>
            {%- if s.bundle_save_note != blank -%}
              <div class="epm-bundle-save">{{ s.bundle_save_note }}</div>
            {%- endif -%}
          </div>

        </div>
      {%- endif -%}

      {%- comment -%} Varianti {%- endcomment -%}
      {%- unless p.has_only_default_variant -%}
        <div class="epm-variants">
          {%- for option in p.options_with_values -%}
            <span class="epm-variant-label">{{ option.name }}</span>
            <div class="epm-variant-btns" id="epm-opt-{{ sid }}-{{ forloop.index0 }}">
              {%- for value in option.values -%}
                {%- assign is_sel = false -%}
                {%- if variant.options[forloop.parentloop.index0] == value -%}
                  {%- assign is_sel = true -%}
                {%- endif -%}
                <button class="epm-variant-btn {% if is_sel %}sel{% endif %}"
                        data-option="{{ forloop.parentloop.index0 }}"
                        data-value="{{ value | escape }}"
                        onclick="epmVariant_{{ sid }}(this)">
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      {%- comment -%} Payment options {%- endcomment -%}
      {%- if pay_opts.size > 0 -%}
        <span class="epm-pay-label">Payment options</span>
        <div class="epm-pay-opts" id="epm-pay-{{ sid }}">
          {%- for block in pay_opts -%}
            <div class="epm-pay-opt {% if forloop.first %}sel{% endif %}"
                 onclick="epmSelectPay_{{ sid }}(this)"
                 {{ block.shopify_attributes }}>
              <div class="epm-po-lbl">{{ block.settings.label }}</div>
              <div class="epm-po-amount">{{ block.settings.amount }}</div>
              {%- if block.settings.note != blank -%}
                <div class="epm-po-note">{{ block.settings.note }}</div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Quantità + ATC {%- endcomment -%}
      {%- form 'product', p, id: "epm-form-{{ sid }}" -%}
        <input type="hidden" name="id" value="{{ variant.id }}" id="epm-variant-id-{{ sid }}">

        <div class="epm-qty-row">
          <span class="epm-qty-lbl">Qty</span>
          <div class="epm-qty-ctrl">
            <button type="button" class="epm-qty-btn"
                    onclick="epmQty_{{ sid }}(-1)" aria-label="Diminuisci">−</button>
            <input type="number" name="quantity" min="1" value="1"
                   id="epm-qty-{{ sid }}" class="epm-qty-input">
            <button type="button" class="epm-qty-btn"
                    onclick="epmQty_{{ sid }}(1)" aria-label="Aumenta">+</button>
          </div>
        </div>

        <button type="submit"
                class="epm-atc-btn"
                id="epm-atc-{{ sid }}"
                {% unless p.available %}disabled{% endunless %}>
          {%- if p.available -%}
            {{ s.btn_text | default: 'Add to Cart' }}
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- if s.atc_note != blank -%}
        <div class="epm-atc-note">{{ s.atc_note }}</div>
      {%- endif -%}

      {%- comment -%} Accordion {%- endcomment -%}
      {%- if accordion_items.size > 0 -%}
        <div class="epm-accordion">
          {%- for block in accordion_items -%}
            <div class="epm-acc-item" {{ block.shopify_attributes }}>
              <button class="epm-acc-h" onclick="epmToggleAcc_{{ sid }}(this)">
                {{ block.settings.heading }}
                <span class="epm-acc-arrow {% if forloop.first %}open{% endif %}">&#8964;</span>
              </button>
              <div class="epm-acc-b {% if forloop.first %}open{% endif %}">
                {{ block.settings.content }}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{%- comment -%} Sticky CTA {%- endcomment -%}
{%- if s.show_sticky -%}
<div class="epm-sticky" id="epm-sticky-{{ sid }}">
  <div>
    <div class="sc-name">{{ p.title }}</div>
    <div class="sc-price">{{ variant.price | money }}</div>
    {%- if s.show_edition and s.edition_total > 0 -%}
      <div class="sc-ed">{{ s.edition_claimed }} / {{ s.edition_total }} claimed</div>
    {%- endif -%}
  </div>
  <button class="sc-btn"
          onclick="document.getElementById('epm-form-{{ sid }}').querySelector('[type=submit]').click()">
    {{ s.btn_text | default: 'Add to Cart' }}
  </button>
</div>
{%- endif -%}

<script>
(function() {
  function epmQty_{{ sid }}(delta) {
    var inp = document.getElementById('epm-qty-{{ sid }}');
    if (!inp) return;
    inp.value = Math.max(1, (parseInt(inp.value, 10) || 1) + delta);
  }
  window.epmQty_{{ sid }} = epmQty_{{ sid }};

  function epmSelectPay_{{ sid }}(el) {
    document.querySelectorAll('#epm-pay-{{ sid }} .epm-pay-opt').forEach(function(o) {
      o.classList.remove('sel');
    });
    el.classList.add('sel');
  }
  window.epmSelectPay_{{ sid }} = epmSelectPay_{{ sid }};

  var variantData = {{ p.variants | json }};
  function epmVariant_{{ sid }}(btn) {
    var optIdx = parseInt(btn.dataset.option, 10);
    var group = document.getElementById('epm-opt-{{ sid }}-' + optIdx);
    if (group) group.querySelectorAll('.epm-variant-btn').forEach(function(b) { b.classList.remove('sel'); });
    btn.classList.add('sel');
    var selected = [];
    for (var i = 0; i < {{ p.options.size }}; i++) {
      var grp = document.getElementById('epm-opt-{{ sid }}-' + i);
      if (grp) {
        var selBtn = grp.querySelector('.epm-variant-btn.sel');
        selected.push(selBtn ? selBtn.dataset.value : '');
      }
    }
    var match = variantData.find(function(v) {
      return v.options.join('|') === selected.join('|');
    });
    if (match) {
      var idInput = document.getElementById('epm-variant-id-{{ sid }}');
      if (idInput) idInput.value = match.id;
    }
  }
  window.epmVariant_{{ sid }} = epmVariant_{{ sid }};

  function epmBundleAcc_{{ sid }}(btn) {
    var body  = document.getElementById('epm-bundle-body-{{ sid }}');
    var arrow = btn.querySelector('.epm-bundle-acc-arrow');
    var open  = body.classList.contains('open');
    body.classList.toggle('open', !open);
    if (arrow) arrow.classList.toggle('open', !open);
    btn.setAttribute('aria-expanded', String(!open));
  }
  window.epmBundleAcc_{{ sid }} = epmBundleAcc_{{ sid }};

  function epmToggleAcc_{{ sid }}(header) {
    var arrow = header.querySelector('.epm-acc-arrow');
    var body  = header.nextElementSibling;
    var open  = body.classList.contains('open');
    body.classList.toggle('open', !open);
    if (arrow) arrow.classList.toggle('open', !open);
  }
  window.epmToggleAcc_{{ sid }} = epmToggleAcc_{{ sid }};

  var sticky = document.getElementById('epm-sticky-{{ sid }}');
  var atcBtn = document.getElementById('epm-atc-{{ sid }}');
  if (sticky && atcBtn) {
    new IntersectionObserver(function(entries) {
      sticky.classList.toggle('vis', !entries[0].isIntersecting);
    }, { threshold: 0 }).observe(atcBtn);
  }

  /* ── Mobile slider dots ── */
  var gallery = document.getElementById('epm-gallery-{{ sid }}');
  var dotsWrap = document.getElementById('epm-dots-{{ sid }}');
  if (gallery && dotsWrap) {
    var dots = dotsWrap.querySelectorAll('.epm-dot');
    var ticking = false;
    gallery.addEventListener('scroll', function() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function() {
        var idx = Math.round(gallery.scrollLeft / gallery.offsetWidth);
        dots.forEach(function(d, i) {
          d.classList.toggle('active', i === idx);
        });
        ticking = false;
      });
    }, { passive: true });
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        var i = parseInt(dot.dataset.index, 10);
        gallery.scrollTo({ left: i * gallery.offsetWidth, behavior: 'smooth' });
      });
    });
  }
})();
</script>

{% schema %}
{
  "name": "Prodotto — Main",
  "tag": "section",
  "templates": ["product"],
  "blocks": [
    {
      "type": "bundle_item",
      "name": "Voce bundle",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "item",  "label": "Descrizione" },
        { "type": "text", "id": "price", "label": "Prezzo / nota (es. €760 o incl.)" }
      ]
    },
    {
      "type": "accordion_item",
      "name": "Accordion",
      "limit": 6,
      "settings": [
        { "type": "text",     "id": "heading", "label": "Titolo",    "default": "Product Details" },
        { "type": "richtext", "id": "content", "label": "Contenuto" }
      ]
    },
    {
      "type": "payment_option",
      "name": "Opzione pagamento",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "label",  "label": "Label",  "default": "Pay in full" },
        { "type": "text", "id": "amount", "label": "Importo","default": "€700" },
        { "type": "text", "id": "note",   "label": "Nota" }
      ]
    }
  ],
  "settings": [
    { "type": "text",     "id": "collection_label",      "label": "Label collezione (override auto)" },
    { "type": "text",     "id": "subtitle",              "label": "Sottotitolo (italic)" },
    { "type": "header",   "content": "Edition counter" },
    { "type": "checkbox", "id": "show_edition",          "label": "Mostra edition counter", "default": false },
    { "type": "number",   "id": "edition_claimed",       "label": "Pezzi reclamati",        "default": 0 },
    { "type": "number",   "id": "edition_total",         "label": "Edizione totale",        "default": 100 },
    { "type": "text",     "id": "edition_ships",         "label": "Testo spedizione" },
    { "type": "header",   "content": "Bundle box" },
    { "type": "text",     "id": "bundle_title",          "label": "Titolo box" },
    { "type": "text",     "id": "bundle_original_price", "label": "Valore bundle (barrato)" },
    { "type": "text",     "id": "bundle_discount_label", "label": "Label sconto" },
    { "type": "text",     "id": "bundle_discount_amount","label": "Importo sconto" },
    { "type": "text",     "id": "bundle_total_label",    "label": "Label prezzo totale",    "default": "Your price today" },
    { "type": "text",     "id": "bundle_save_note",      "label": "Nota verde" },
    { "type": "header",   "content": "Acquisto" },
    { "type": "text",     "id": "btn_text",              "label": "Testo bottone",          "default": "Add to Cart" },
    { "type": "text",     "id": "atc_note",              "label": "Nota sotto bottone" },
    { "type": "checkbox", "id": "show_sticky",           "label": "Mostra sticky CTA",     "default": true }
  ],
  "presets": [{ "name": "Prodotto — Main" }]
}
{% endschema %}
