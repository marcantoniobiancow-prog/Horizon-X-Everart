{%- comment -%}
  EverArt Product Main — v1
  Gallery + breadcrumb + info panel + sticky CTA
  Blocks: bundle_item, accordion_item
{%- endcomment -%}

{%- assign s       = section.settings -%}
{%- assign sid     = section.id -%}
{%- assign p       = product -%}
{%- assign variant = p.selected_or_first_available_variant -%}
{%- assign media   = p.media -%}

{%- liquid
  assign col_title = s.collection_label
  if col_title == blank and p.collections.size > 0
    assign col_title = p.collections[0].title
  endif

  assign bundle_items = section.blocks | where: 'type', 'bundle_item'
  assign accordion_items = section.blocks | where: 'type', 'accordion_item'
  assign pay_opts = section.blocks | where: 'type', 'payment_option'
-%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap');

#epm-{{ sid }},
#epm-sticky-{{ sid }} {
  background: #0a0a0a;
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  color: #ffffff;
}

/* ── Breadcrumb ── */
#epm-{{ sid }} .epm-breadcrumb {
  font-size: 10.5px;
  letter-spacing: .08em;
  color: #888888;
  display: flex;
  gap: 10px;
  align-items: center;
  padding: 18px 48px;
  border-bottom: 1px solid #2a2a2a;
  background: #121212;
}
#epm-{{ sid }} .epm-breadcrumb a {
  color: #888888;
  text-decoration: none;
  transition: color .2s;
}
#epm-{{ sid }} .epm-breadcrumb a:hover { color: #ffffff; }
#epm-{{ sid }} .epm-breadcrumb span { color: #888888; }
#epm-{{ sid }} .epm-breadcrumb .epm-bc-current { color: #cccccc; }

/* ── Page grid ── */
#epm-{{ sid }} .epm-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: start;
  max-width: 1200px;
  margin: 0 auto;
}

/* ── Gallery ── */
#epm-{{ sid }} .epm-gallery {
  padding: 48px 56px 48px 48px;
  border-right: 1px solid #2a2a2a;
  position: sticky;
  top: 0;
}
#epm-{{ sid }} .epm-gallery-main {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #212121;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}
#epm-{{ sid }} .epm-gallery-main img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
#epm-{{ sid }} .epm-gallery-thumbs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
}
#epm-{{ sid }} .epm-thumb {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  cursor: pointer;
  opacity: 0.45;
  transition: opacity .2s;
  background: #212121;
}
#epm-{{ sid }} .epm-thumb:hover,
#epm-{{ sid }} .epm-thumb.sel { opacity: 1; }
#epm-{{ sid }} .epm-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Info panel ── */
#epm-{{ sid }} .epm-info {
  padding: 48px 48px 48px 56px;
}
#epm-{{ sid }} .epm-tag {
  font-size: 9.5px;
  letter-spacing: .26em;
  text-transform: uppercase;
  color: #888888;
  display: block;
  margin-bottom: 12px;
  font-weight: 500;
}
#epm-{{ sid }} .epm-title {
  font-size: clamp(36px, 4vw, 52px);
  line-height: 1.0;
  font-weight: 800;
  letter-spacing: -.03em;
  margin: 0 0 4px;
  color: #ffffff;
}
#epm-{{ sid }} .epm-sub {
  font-size: 13px;
  color: #888888;
  font-style: italic;
  margin-bottom: 36px;
  font-weight: 400;
  letter-spacing: .04em;
}

/* ── Edition counter ── */
#epm-{{ sid }} .epm-edition {
  margin-bottom: 32px;
}
#epm-{{ sid }} .epm-edition-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
#epm-{{ sid }} .epm-edition-lbl {
  font-size: 9.5px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: #888888;
  font-weight: 600;
}
#epm-{{ sid }} .epm-edition-count {
  font-size: 10px;
  color: #888888;
  font-weight: 500;
}
#epm-{{ sid }} .epm-edition-count strong {
  color: #ffffff;
}
#epm-{{ sid }} .epm-edition-track {
  height: 3px;
  background: #2a2a2a;
  position: relative;
  overflow: hidden;
}
#epm-{{ sid }} .epm-edition-fill {
  position: absolute;
  left: 0; top: 0;
  height: 100%;
  background: #ffffff;
  transition: width .6s ease;
}

/* ── Bundle box ── */
#epm-{{ sid }} .epm-bundle {
  background: #121212;
  padding: 24px;
  margin-bottom: 24px;
}
#epm-{{ sid }} .epm-bundle-title {
  font-size: 9.5px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: #888888;
  margin-bottom: 16px;
  font-weight: 600;
}
#epm-{{ sid }} .epm-bundle-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #2a2a2a;
  font-size: 13px;
}
#epm-{{ sid }} .epm-bundle-line:last-of-type { border: none; }
#epm-{{ sid }} .epm-bundle-item { color: #cccccc; font-weight: 400; }
#epm-{{ sid }} .epm-bundle-price { color: #888888; font-weight: 500; font-size: 14px; }
#epm-{{ sid }} .epm-bundle-total {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16px 0 0;
  margin-top: 8px;
  border-top: 1px solid #2a2a2a;
}
#epm-{{ sid }} .epm-bundle-total-lbl {
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  font-weight: 700;
  color: #ffffff;
}
#epm-{{ sid }} .epm-bundle-total-price {
  font-size: 36px;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -.03em;
}
#epm-{{ sid }} .epm-bundle-save {
  font-size: 10px;
  color: #5a9a5a;
  margin-top: 6px;
  text-align: right;
  letter-spacing: .05em;
  font-weight: 500;
}

/* ── Payment options ── */
#epm-{{ sid }} .epm-pay-label {
  font-size: 9.5px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: #888888;
  margin-bottom: 10px;
  font-weight: 600;
  display: block;
}
#epm-{{ sid }} .epm-pay-opts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
  margin-bottom: 16px;
}
#epm-{{ sid }} .epm-pay-opt {
  border: 1px solid #2a2a2a;
  padding: 16px 18px;
  cursor: pointer;
  transition: border-color .2s;
  background: #0a0a0a;
}
#epm-{{ sid }} .epm-pay-opt.sel { border-color: #ffffff; }
#epm-{{ sid }} .epm-po-lbl {
  font-size: 9px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: #888888;
  margin-bottom: 4px;
  font-weight: 600;
}
#epm-{{ sid }} .epm-po-amount {
  font-size: 22px;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -.02em;
}
#epm-{{ sid }} .epm-po-note {
  font-size: 10px;
  color: #888888;
  margin-top: 2px;
  font-weight: 400;
}

/* ── ATC button ── */
#epm-{{ sid }} .epm-atc-btn {
  width: 100%;
  background: #8b1a1a;
  color: #ffffff;
  padding: 18px;
  font-size: 11px;
  letter-spacing: .26em;
  text-transform: uppercase;
  font-weight: 700;
  cursor: pointer;
  margin-bottom: 10px;
  transition: background .2s;
  border: none;
  font-family: 'Instrument Sans', sans-serif;
}
#epm-{{ sid }} .epm-atc-btn:hover { background: #a52020; }
#epm-{{ sid }} .epm-atc-btn:disabled { opacity: .45; cursor: default; }
#epm-{{ sid }} .epm-atc-note {
  font-size: 11px;
  color: #888888;
  text-align: center;
  letter-spacing: .05em;
  font-weight: 400;
}

/* ── Accordion ── */
#epm-{{ sid }} .epm-accordion {
  border-top: 1px solid #2a2a2a;
  margin-top: 32px;
}
#epm-{{ sid }} .epm-acc-item {
  border-bottom: 1px solid #2a2a2a;
}
#epm-{{ sid }} .epm-acc-h {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  cursor: pointer;
  font-size: 11px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: #cccccc;
  font-weight: 600;
  user-select: none;
}
#epm-{{ sid }} .epm-acc-h:hover { color: #ffffff; }
#epm-{{ sid }} .epm-acc-arrow {
  color: #888888;
  font-size: 16px;
  transition: transform .2s;
  line-height: 1;
  font-weight: 300;
  flex-shrink: 0;
}
#epm-{{ sid }} .epm-acc-arrow.open { transform: rotate(180deg); }
#epm-{{ sid }} .epm-acc-b {
  padding: 0 0 20px;
  font-size: 13px;
  color: #888888;
  line-height: 1.8;
  display: none;
  font-weight: 400;
}
#epm-{{ sid }} .epm-acc-b.open { display: block; }
#epm-{{ sid }} .epm-acc-b p { margin-bottom: 12px; }
#epm-{{ sid }} .epm-spec-t { width: 100%; border-collapse: collapse; }
#epm-{{ sid }} .epm-spec-t tr { border-bottom: 1px solid #2a2a2a; }
#epm-{{ sid }} .epm-spec-t td { padding: 9px 0; font-size: 13px; }
#epm-{{ sid }} .epm-spec-t td:first-child { color: #888888; width: 44%; font-weight: 400; }
#epm-{{ sid }} .epm-spec-t td:last-child { color: #ffffff; font-weight: 500; }

/* ── Sticky CTA ── */
#epm-sticky-{{ sid }} {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(10,10,10,.97);
  backdrop-filter: blur(12px);
  border-top: 1px solid #2a2a2a;
  padding: 14px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 300;
  transform: translateY(100%);
  transition: transform .3s ease;
}
#epm-sticky-{{ sid }}.vis { transform: translateY(0); }
#epm-sticky-{{ sid }} .sc-name { font-size: 15px; font-weight: 700; letter-spacing: -.01em; }
#epm-sticky-{{ sid }} .sc-price { font-size: 28px; font-weight: 800; letter-spacing: -.02em; }
#epm-sticky-{{ sid }} .sc-ed { font-size: 10px; color: #888888; letter-spacing: .06em; margin-top: 2px; font-weight: 400; }
#epm-sticky-{{ sid }} .sc-btn {
  background: #8b1a1a;
  color: #ffffff;
  border: none;
  padding: 14px 32px;
  font-size: 10px;
  letter-spacing: .24em;
  text-transform: uppercase;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Instrument Sans', sans-serif;
  transition: background .2s;
  white-space: nowrap;
}
#epm-sticky-{{ sid }} .sc-btn:hover { background: #a52020; }

/* ── Mobile ── */
@media (max-width: 767px) {
  #epm-{{ sid }} .epm-breadcrumb { padding: 14px 20px; }
  #epm-{{ sid }} .epm-grid { grid-template-columns: 1fr; }
  #epm-{{ sid }} .epm-gallery { padding: 0; border-right: none; position: static; }
  #epm-{{ sid }} .epm-gallery-main { aspect-ratio: 1 / 1; margin-bottom: 4px; }
  #epm-{{ sid }} .epm-gallery-thumbs { gap: 3px; }
  #epm-{{ sid }} .epm-info { padding: 32px 20px 48px; }
  #epm-{{ sid }} .epm-pay-opts { grid-template-columns: 1fr; }
  #epm-sticky-{{ sid }} { padding: 12px 20px; }
  #epm-sticky-{{ sid }} .sc-price { font-size: 20px; }
}
</style>

{%- comment -%} Breadcrumb {%- endcomment -%}
<div id="epm-{{ sid }}">
<div class="epm-breadcrumb">
  <a href="/">Home</a>
  <span>/</span>
  {%- if p.collections.size > 0 -%}
    <a href="{{ p.collections[0].url }}">{{ p.collections[0].title }}</a>
    <span>/</span>
  {%- endif -%}
  <span class="epm-bc-current">{{ p.title }}</span>
</div>

{%- comment -%} Main grid {%- endcomment -%}
<div class="epm-grid">

  {%- comment -%} Gallery {%- endcomment -%}
  <div class="epm-gallery">
    <div class="epm-gallery-main">
      {%- if media.size > 0 -%}
        <img id="epm-main-img-{{ sid }}"
             src="{{ media[0] | image_url: width: 1000 }}"
             alt="{{ media[0].alt | default: p.title }}"
             width="1000"
             loading="eager">
      {%- endif -%}
    </div>
    {%- if media.size > 1 -%}
      <div class="epm-gallery-thumbs">
        {%- for m in media limit: 4 -%}
          <div class="epm-thumb {% if forloop.first %}sel{% endif %}"
               data-full="{{ m | image_url: width: 1000 }}"
               onclick="epmSelectThumb_{{ sid }}(this, {{ forloop.index0 }})">
            <img src="{{ m | image_url: width: 200 }}"
                 alt="{{ m.alt | default: p.title }}"
                 width="200"
                 loading="lazy">
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Info panel {%- endcomment -%}
  <div class="epm-info">
    {%- if col_title != blank -%}
      <span class="epm-tag">{{ col_title }}</span>
    {%- endif -%}
    <h1 class="epm-title">{{ p.title }}</h1>
    {%- assign sub = s.subtitle | default: p.type -%}
    {%- if sub != blank -%}
      <div class="epm-sub">{{ sub }}</div>
    {%- endif -%}

    {%- comment -%} Edition counter {%- endcomment -%}
    {%- if s.show_edition and s.edition_total > 0 -%}
      {%- assign pct = s.edition_claimed | times: 100.0 | divided_by: s.edition_total | round -%}
      <div class="epm-edition">
        <div class="epm-edition-label">
          <span class="epm-edition-lbl">Edition Progress</span>
          <span class="epm-edition-count">
            <strong>{{ s.edition_claimed }}</strong> / {{ s.edition_total }} claimed
            {%- if s.edition_ships != blank %} · {{ s.edition_ships }}{%- endif -%}
          </span>
        </div>
        <div class="epm-edition-track">
          <div class="epm-edition-fill" style="width:{{ pct }}%"></div>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Bundle box {%- endcomment -%}
    {%- if bundle_items.size > 0 -%}
      <div class="epm-bundle">
        {%- if s.bundle_title != blank -%}
          <div class="epm-bundle-title">{{ s.bundle_title }}</div>
        {%- endif -%}
        {%- for block in bundle_items -%}
          <div class="epm-bundle-line" {{ block.shopify_attributes }}>
            <span class="epm-bundle-item">{{ block.settings.item }}</span>
            <span class="epm-bundle-price">{{ block.settings.price }}</span>
          </div>
        {%- endfor -%}
        {%- if s.bundle_original_price != blank or s.bundle_discount_label != blank -%}
          <div class="epm-bundle-line" style="border-top:1px solid #2a2a2a;margin-top:4px;padding-top:12px">
            <span class="epm-bundle-item" style="color:#888888">Bundle value</span>
            <span class="epm-bundle-price" style="text-decoration:line-through">{{ s.bundle_original_price }}</span>
          </div>
        {%- endif -%}
        {%- if s.bundle_discount_label != blank -%}
          <div class="epm-bundle-line" style="padding-top:4px">
            <span class="epm-bundle-item" style="color:#c44;">{{ s.bundle_discount_label }}</span>
            <span class="epm-bundle-price" style="color:#c44;">{{ s.bundle_discount_amount }}</span>
          </div>
        {%- endif -%}
        <div class="epm-bundle-total">
          <span class="epm-bundle-total-lbl">{{ s.bundle_total_label | default: 'Your price today' }}</span>
          <span class="epm-bundle-total-price">{{ variant.price | money }}</span>
        </div>
        {%- if s.bundle_save_note != blank -%}
          <div class="epm-bundle-save">{{ s.bundle_save_note }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Payment options {%- endcomment -%}
    {%- if pay_opts.size > 0 -%}
      <span class="epm-pay-label">Payment options</span>
      <div class="epm-pay-opts" id="epm-pay-{{ sid }}">
        {%- for block in pay_opts -%}
          <div class="epm-pay-opt {% if forloop.first %}sel{% endif %}"
               onclick="epmSelectPay_{{ sid }}(this)"
               {{ block.shopify_attributes }}>
            <div class="epm-po-lbl">{{ block.settings.label }}</div>
            <div class="epm-po-amount">{{ block.settings.amount }}</div>
            {%- if block.settings.note != blank -%}
              <div class="epm-po-note">{{ block.settings.note }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ATC form {%- endcomment -%}
    {%- form 'product', p, id: "epm-form-{{ sid }}" -%}
      <input type="hidden" name="id" value="{{ variant.id }}">
      <button type="submit"
              class="epm-atc-btn"
              id="epm-atc-{{ sid }}"
              {% unless p.available %}disabled{% endunless %}>
        {%- if p.available -%}
          {{ s.btn_text | default: 'Add to Cart' }}
        {%- else -%}
          Sold Out
        {%- endif -%}
      </button>
    {%- endform -%}
    {%- if s.atc_note != blank -%}
      <div class="epm-atc-note">{{ s.atc_note }}</div>
    {%- endif -%}

    {%- comment -%} Accordion {%- endcomment -%}
    {%- if accordion_items.size > 0 -%}
      <div class="epm-accordion">
        {%- for block in accordion_items -%}
          <div class="epm-acc-item" {{ block.shopify_attributes }}>
            <div class="epm-acc-h" onclick="epmToggleAcc_{{ sid }}(this)">
              {{ block.settings.heading }}
              <span class="epm-acc-arrow {% if forloop.first %}open{% endif %}">&#8964;</span>
            </div>
            <div class="epm-acc-b {% if forloop.first %}open{% endif %}">
              {{ block.settings.content }}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>
</div>

{%- comment -%} Sticky CTA {%- endcomment -%}
{%- if s.show_sticky -%}
<div id="epm-sticky-{{ sid }}">
  <div>
    <div class="sc-name">{{ p.title }}</div>
    <div class="sc-price">{{ variant.price | money }}</div>
    {%- if s.show_edition and s.edition_total > 0 -%}
      <div class="sc-ed">{{ s.edition_claimed }} / {{ s.edition_total }} claimed</div>
    {%- endif -%}
  </div>
  <button class="sc-btn" onclick="document.getElementById('epm-form-{{ sid }}').submit()">
    {{ s.btn_text | default: 'Add to Cart' }}
  </button>
</div>
{%- endif -%}

<script>
(function() {
  /* Gallery thumbnails */
  function epmSelectThumb_{{ sid }}(el, idx) {
    var mainImg = document.getElementById('epm-main-img-{{ sid }}');
    var thumbs  = document.querySelectorAll('#epm-{{ sid }} .epm-thumb');
    thumbs.forEach(function(t) { t.classList.remove('sel'); });
    el.classList.add('sel');
    if (mainImg) mainImg.src = el.dataset.full;
  }
  window.epmSelectThumb_{{ sid }} = epmSelectThumb_{{ sid }};

  /* Payment option toggle */
  function epmSelectPay_{{ sid }}(el) {
    var opts = document.querySelectorAll('#epm-pay-{{ sid }} .epm-pay-opt');
    opts.forEach(function(o) { o.classList.remove('sel'); });
    el.classList.add('sel');
  }
  window.epmSelectPay_{{ sid }} = epmSelectPay_{{ sid }};

  /* Accordion */
  function epmToggleAcc_{{ sid }}(header) {
    var arrow = header.querySelector('.epm-acc-arrow');
    var body  = header.nextElementSibling;
    var isOpen = body.classList.contains('open');
    body.classList.toggle('open', !isOpen);
    arrow.classList.toggle('open', !isOpen);
  }
  window.epmToggleAcc_{{ sid }} = epmToggleAcc_{{ sid }};

  /* Sticky CTA */
  var sticky = document.getElementById('epm-sticky-{{ sid }}');
  var atcBtn = document.getElementById('epm-atc-{{ sid }}');
  if (sticky && atcBtn) {
    var obs = new IntersectionObserver(function(entries) {
      sticky.classList.toggle('vis', !entries[0].isIntersecting);
    }, { threshold: 0 });
    obs.observe(atcBtn);
  }
})();
</script>

{% schema %}
{
  "name": "Prodotto — Main",
  "tag": "section",
  "templates": ["product"],
  "blocks": [
    {
      "type": "bundle_item",
      "name": "Voce bundle",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "item", "label": "Descrizione voce" },
        { "type": "text", "id": "price", "label": "Prezzo / nota (es. €760 o incl.)" }
      ]
    },
    {
      "type": "accordion_item",
      "name": "Accordion",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "heading", "label": "Titolo", "default": "Product Details" },
        { "type": "richtext", "id": "content", "label": "Contenuto" }
      ]
    },
    {
      "type": "payment_option",
      "name": "Opzione pagamento",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Pay in full" },
        { "type": "text", "id": "amount", "label": "Importo", "default": "€700" },
        { "type": "text", "id": "note", "label": "Nota sotto importo" }
      ]
    }
  ],
  "settings": [
    { "type": "text",     "id": "collection_label", "label": "Label collezione (override auto)" },
