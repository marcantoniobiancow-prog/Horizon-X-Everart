{%- liquid
  assign s   = section.settings
  assign sid = section.id
-%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');

#emc-{{ sid }} {
  background: #0a0a0a;
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  padding-top: 0;
}

#emc-{{ sid }} .emc-head {
  max-width: 1200px;
  margin: 0 auto;
  padding: 80px 48px 48px;
}

#emc-{{ sid }} .emc-label {
  font-size: 10px;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: #888888;
  font-weight: 500;
  margin: 0 0 14px;
}

#emc-{{ sid }} .emc-section-title {
  font-size: clamp(28px, 3.5vw, 44px);
  font-weight: 700;
  letter-spacing: -.02em;
  line-height: 1.05;
  color: #ffffff;
  margin: 0;
}

/* ── AUTHOR CARDS GRID ── */
#emc-{{ sid }} .emc-authors {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1px;
  background: #2a2a2a;
}

#emc-{{ sid }} .emc-card {
  position: relative;
  min-height: 480px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
  background: #111111;
  text-decoration: none;
  color: inherit;
}

#emc-{{ sid }} .emc-card-img {
  position: absolute;
  inset: 0;
  z-index: 0;
  background: #111111;
}

#emc-{{ sid }} .emc-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .8s ease;
}

@media (hover: hover) {
  #emc-{{ sid }} .emc-card:hover .emc-card-img img {
    transform: scale(1.03);
  }
}

#emc-{{ sid }} .emc-card.ea-zoom .emc-card-img img {
  transform: scale(1.03);
}

#emc-{{ sid }} .emc-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(5,5,5,.97) 0%, rgba(5,5,5,.4) 55%, transparent 100%);
  z-index: 1;
}

#emc-{{ sid }} .emc-body {
  position: relative;
  z-index: 2;
  padding: 48px 56px;
}

#emc-{{ sid }} .emc-tag {
  display: inline-block;
  border: 1px solid #8b1a1a;
  color: #8b1a1a;
  background: transparent;
  font-size: 9px;
  letter-spacing: .24em;
  text-transform: uppercase;
  padding: 4px 12px;
  margin-bottom: 16px;
  font-weight: 600;
}

#emc-{{ sid }} .emc-title {
  font-size: 40px;
  line-height: 1.0;
  font-weight: 700;
  letter-spacing: -.02em;
  margin: 0 0 8px;
  color: #ffffff;
}

#emc-{{ sid }} .emc-sub {
  font-size: 13px;
  color: #888888;
  margin: 0 0 28px;
  font-weight: 400;
  font-style: italic;
}

#emc-{{ sid }} .emc-btn {
  display: inline-block;
  background: #8b1a1a;
  color: #ffffff;
  border: none;
  padding: 13px 24px;
  font-size: 9px;
  letter-spacing: .22em;
  text-transform: uppercase;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Instrument Sans', sans-serif;
  text-decoration: none;
  transition: background .2s;
}

#emc-{{ sid }} .emc-btn:hover {
  background: #a52020;
}

/* ── RESPONSIVE ── */
@media (max-width: 1023px) {
  #emc-{{ sid }} .emc-authors { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 767px) {
  #emc-{{ sid }} .emc-head { padding: 60px 24px 36px; }
  #emc-{{ sid }} .emc-authors { grid-template-columns: 1fr; }
  #emc-{{ sid }} .emc-card { min-height: 420px; }
  #emc-{{ sid }} .emc-body { padding: 32px 28px; }
  #emc-{{ sid }} .emc-title { font-size: 32px; }
}
</style>

<div id="emc-{{ sid }}">

  {%- if s.section_label != blank or s.section_title != blank -%}
    <div class="emc-head">
      {%- if s.section_label != blank -%}
        <p class="emc-label">{{ s.section_label }}</p>
      {%- endif -%}
      {%- if s.section_title != blank -%}
        <h2 class="emc-section-title">{{ s.section_title }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="emc-authors">

    {%- comment -%} Card 1 {%- endcomment -%}
    <a class="emc-card" href="{{ s.card1_url | default: '/pages/autore-lovecraft' }}">
      <div class="emc-card-img">
        {%- if s.card1_image != blank -%}
          {{ s.card1_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: s.card1_title }}
        {%- endif -%}
      </div>
      <div class="emc-overlay"></div>
      <div class="emc-body">
        {%- if s.card1_tag != blank -%}<span class="emc-tag">{{ s.card1_tag }}</span>{%- endif -%}
        <div class="emc-title">{{ s.card1_title | default: 'H.P. Lovecraft' | newline_to_br }}</div>
        {%- if s.card1_sub != blank -%}<p class="emc-sub">{{ s.card1_sub }}</p>{%- endif -%}
        {%- if s.card1_btn != blank -%}<span class="emc-btn">{{ s.card1_btn }}</span>{%- endif -%}
      </div>
    </a>

    {%- comment -%} Card 2 {%- endcomment -%}
    <a class="emc-card" href="{{ s.card2_url | default: '/pages/autore-mary-shelley' }}">
      <div class="emc-card-img">
        {%- if s.card2_image != blank -%}
          {{ s.card2_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: s.card2_title }}
        {%- endif -%}
      </div>
      <div class="emc-overlay"></div>
      <div class="emc-body">
        {%- if s.card2_tag != blank -%}<span class="emc-tag">{{ s.card2_tag }}</span>{%- endif -%}
        <div class="emc-title">{{ s.card2_title | default: 'Mary Shelley' | newline_to_br }}</div>
        {%- if s.card2_sub != blank -%}<p class="emc-sub">{{ s.card2_sub }}</p>{%- endif -%}
        {%- if s.card2_btn != blank -%}<span class="emc-btn">{{ s.card2_btn }}</span>{%- endif -%}
      </div>
    </a>

    {%- comment -%} Card 3 {%- endcomment -%}
    <a class="emc-card" href="{{ s.card3_url | default: '/pages/autore-bram-stoker' }}">
      <div class="emc-card-img">
        {%- if s.card3_image != blank -%}
          {{ s.card3_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: s.card3_title }}
        {%- endif -%}
      </div>
      <div class="emc-overlay"></div>
      <div class="emc-body">
        {%- if s.card3_tag != blank -%}<span class="emc-tag">{{ s.card3_tag }}</span>{%- endif -%}
        <div class="emc-title">{{ s.card3_title | default: 'Bram Stoker' | newline_to_br }}</div>
        {%- if s.card3_sub != blank -%}<p class="emc-sub">{{ s.card3_sub }}</p>{%- endif -%}
        {%- if s.card3_btn != blank -%}<span class="emc-btn">{{ s.card3_btn }}</span>{%- endif -%}
      </div>
    </a>

  </div>

</div>

<script>
(function(){
  if (window.matchMedia('(hover: none)').matches) {
    var cards = document.querySelectorAll('#emc-{{ sid }} .emc-card');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('ea-zoom'); }
        else { e.target.classList.remove('ea-zoom'); }
      });
    }, { threshold: 0.3 });
    cards.forEach(function(c){ io.observe(c); });
  }
})();
</script>

