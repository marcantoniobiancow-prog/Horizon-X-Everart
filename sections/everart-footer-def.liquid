{%- comment -%}
  EverArt Footer — Definitive v3
  File: sections/everart-footer-def.liquid

  Changes v3:
  • Background full-width (sfondo edge-to-edge) — container_width ora controlla solo il
    max-width del contenuto interno, NON il box del bg
  • Social icons ripristinate: Instagram + Facebook come settings fissi + blocchi aggiuntivi
  • Bottom bar links: Privacy + Terms come settings fissi + blocchi aggiuntivi illimitati
  • Struttura: card = sfondo full-width | inner = contenuto opzionalmente max-width
{%- endcomment -%}

{%- liquid
  assign s                  = section.settings
  assign sid                = section.id
  assign has_logo           = false
  if s.logo != blank
    assign has_logo = true
  endif
  assign logo_behavior       = s.logo_behavior
  assign logo_overflow_scale = s.logo_overflow_scale | divided_by: 100.0

  assign social_blocks = section.blocks | where: "type", "social"
  assign legal_blocks  = section.blocks | where: "type", "legal_link"
  assign contact_blocks = section.blocks | where: "type", "contact_item"
-%}

<style>
/* ============================================================
   ROOT VARIABLES
   ============================================================ */
#ea-footer-def-{{ sid }} {
  --ea-bg:      {{ s.bg_color }};
  --ea-grad:    {{ s.gradient_color }};
  --ea-text:    {{ s.text_color }};
  --ea-radius:  {{ s.border_radius }}px;
  --ea-logo-w:  {{ s.logo_custom_width }}px;
  display: block;
  width: 100%;
  box-sizing: border-box;
  position: relative; /* JS sets padding for logo overflow */
}

/* ============================================================
   CARD — sfondo full-width (non più boxed)
   ============================================================ */
#ea-footer-def-{{ sid }} .eafd-card {
  position: relative;
  background: var(--ea-bg);
  border-radius: var(--ea-radius);
  overflow: visible; /* logo may escape vertically */
  box-sizing: border-box;
  width: 100%;
}

/* ── Animated gradient layer (clipped to card shape) ───────── */
#ea-footer-def-{{ sid }} .eafd-grad-layer {
  position: absolute;
  inset: 0;
  border-radius: var(--ea-radius);
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}
#ea-footer-def-{{ sid }} .eafd-grad-layer::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 40%;
  background: linear-gradient(to top, var(--ea-grad) 0%, transparent 100%);
  opacity: 0.6;
  will-change: height, opacity;
  animation: eafd-breathe-{{ sid }} 3s ease-in-out infinite;
}
@keyframes eafd-breathe-{{ sid }} {
  0%, 100% { height: 40%; opacity: 0.6; }
  50%       { height: 60%; opacity: 1;   }
}

/* ── INNER: contenuto max-width opzionale ──────────────────── */
#ea-footer-def-{{ sid }} .eafd-inner {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 32px 64px;
  box-sizing: border-box;
  width: 100%;
}
{% if s.container_width == 'page' %}
#ea-footer-def-{{ sid }} .eafd-inner {
  max-width: 1440px;
  margin-left: auto;
  margin-right: auto;
}
{% endif %}

/* ============================================================
   LEFT CONTENT
   ============================================================ */
#ea-footer-def-{{ sid }} .eafd-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 40px;
}

/* — Intro —————————————————————————— */
#ea-footer-def-{{ sid }} .eafd-intro {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
#ea-footer-def-{{ sid }} .eafd-label {
  font-family: 'Instrument Sans', sans-serif;
  font-weight: 500;
  font-size: 10px;
  letter-spacing: 0.4px;
  line-height: 1.4;
  text-transform: uppercase;
  color: var(--ea-text);
  margin: 0;
}
#ea-footer-def-{{ sid }} .eafd-heading {
  font-family: 'Instrument Sans', sans-serif;
  font-weight: 700;
  font-size: 32px;
  line-height: 1.2;
  text-transform: uppercase;
  color: var(--ea-text);
  margin: 0;
  max-width: 540px;
}

/* — Nav columns ————————————————————— */
#ea-footer-def-{{ sid }} .eafd-nav {
  display: flex;
  gap: 24px;
  align-items: flex-start;
}
#ea-footer-def-{{ sid }} .eafd-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
#ea-footer-def-{{ sid }} .eafd-col-heading {
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  font-size: 16px;
  line-height: 1.4;
  text-transform: uppercase;
  color: var(--ea-text);
  margin: 0;
}
#ea-footer-def-{{ sid }} .eafd-col-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 5px;
}
#ea-footer-def-{{ sid }} .eafd-col-list a,
#ea-footer-def-{{ sid }} .eafd-col-list span {
  font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-size: 12px;
  line-height: 1.4;
  color: var(--ea-text);
  text-decoration: none;
  display: block;
}
#ea-footer-def-{{ sid }} .eafd-col-list a:hover { text-decoration: underline; }

/* — Bottom bar —————————————————————— */
#ea-footer-def-{{ sid }} .eafd-bottom {
  display: flex;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}
#ea-footer-def-{{ sid }} .eafd-socials {
  display: flex;
  align-items: center;
  gap: 16px;
}
#ea-footer-def-{{ sid }} .eafd-social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 16px;
  height: 16px;
  color: var(--ea-text);
  text-decoration: none;
  flex-shrink: 0;
  transition: opacity 0.2s;
}
#ea-footer-def-{{ sid }} .eafd-social-link:hover { opacity: 0.7; }
#ea-footer-def-{{ sid }} .eafd-social-link svg {
  width: 16px;
  height: 16px;
  fill: currentColor;
  display: block;
}
#ea-footer-def-{{ sid }} .eafd-legal-text {
  font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-size: 10px;
  line-height: 1.4;
  color: var(--ea-text);
  opacity: 0.4;
  margin: 0;
  white-space: nowrap;
  text-decoration: none;
  display: inline-block;
  transition: opacity 0.2s;
}
#ea-footer-def-{{ sid }} a.eafd-legal-text:hover { opacity: 0.7; }

/* ============================================================
   LOGO — DESKTOP (right, flex child, may overflow card)
   ============================================================ */
#ea-footer-def-{{ sid }} .eafd-logo-desktop {
  flex-shrink: 0;
  align-self: center;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
#ea-footer-def-{{ sid }} .eafd-logo-desktop img {
  display: block;
  height: auto;
  width: auto;
}
{% if logo_behavior == 'fill' %}
#ea-footer-def-{{ sid }} .eafd-logo-desktop { align-self: stretch; }
#ea-footer-def-{{ sid }} .eafd-logo-desktop img { height: 100%; width: auto; object-fit: contain; }
{% elsif logo_behavior == 'custom' %}
#ea-footer-def-{{ sid }} .eafd-logo-desktop img { width: var(--ea-logo-w); height: auto; }
{% endif %}

/* ============================================================
   LOGO — MOBILE (top of section, overflow upward only)
   ============================================================ */
#ea-footer-def-{{ sid }} .eafd-logo-mobile {
  display: none;
  justify-content: center;
  align-items: flex-end;
  position: relative;
  z-index: 2;
}
#ea-footer-def-{{ sid }} .eafd-logo-mobile img {
  display: block;
  height: auto;
  width: min(55vw, 260px);
}
{% if logo_behavior == 'custom' %}
#ea-footer-def-{{ sid }} .eafd-logo-mobile img { width: min(var(--ea-logo-w), 72vw); }
{% endif %}

/* ============================================================
   MOBILE — ≤ 767px
   ============================================================ */
@media (max-width: 767px) {
  #ea-footer-def-{{ sid }} .eafd-logo-desktop { display: none !important; }
  #ea-footer-def-{{ sid }} .eafd-logo-mobile  { display: flex; }
  #ea-footer-def-{{ sid }} .eafd-inner {
    flex-direction: column;
    align-items: stretch;
    padding: 28px 24px;
    gap: 32px;
  }
  #ea-footer-def-{{ sid }} .eafd-heading {
    font-size: clamp(20px, 5vw, 28px);
    max-width: 100%;
  }
  #ea-footer-def-{{ sid }} .eafd-nav    { flex-direction: column; gap: 28px; }
  #ea-footer-def-{{ sid }} .eafd-bottom { gap: 16px; row-gap: 8px; }
}

/* ============================================================
   TABLET — 768px – 1023px
   ============================================================ */
@media (min-width: 768px) and (max-width: 1023px) {
  #ea-footer-def-{{ sid }} .eafd-inner  { padding: 32px 40px; gap: 16px; }
  #ea-footer-def-{{ sid }} .eafd-heading { font-size: 26px; }
}
</style>

{%- comment -%}
  ─── SVG icon helper ────────────────────────────────────────
  Usage: assign _platform = 'instagram' then render this capture
{%- endcomment -%}

<div id="ea-footer-def-{{ sid }}"
     data-logo-behavior="{{ logo_behavior }}"
     data-logo-scale="{{ logo_overflow_scale }}">

  {%- comment -%}— MOBILE LOGO (above card) —{%- endcomment -%}
  {%- if has_logo -%}
  <div class="eafd-logo-mobile" id="eafd-logo-mobile-{{ sid }}">
    <img
      src="{{ s.logo | image_url: width: 600 }}"
      alt="{{ shop.name }}"
      loading="lazy"
      width="{{ s.logo.width }}"
      height="{{ s.logo.height }}"
    >
  </div>
  {%- endif -%}

  {%- comment -%}— CARD: full-width sfondo scuro —{%- endcomment -%}
  <div class="eafd-card" id="eafd-card-{{ sid }}">

    {%- comment -%}Gradient animato (clipped nel card){%- endcomment -%}
    <div class="eafd-grad-layer" aria-hidden="true"></div>

    {%- comment -%}— INNER: contenuto (opzionalmente max-width) —{%- endcomment -%}
    <div class="eafd-inner">

      {%- comment -%}— LEFT CONTENT —{%- endcomment -%}
      <div class="eafd-content">

        {%- comment -%}INTRO{%- endcomment -%}
        <div class="eafd-intro">
          {%- if s.label_text != blank -%}
            <p class="eafd-label">{{ s.label_text }}</p>
          {%- endif -%}
          {%- if s.heading_text != blank -%}
            <h2 class="eafd-heading">{{ s.heading_text }}</h2>
          {%- endif -%}
        </div>

        {%- comment -%}NAV COLUMNS{%- endcomment -%}
        <div class="eafd-nav">

          {%- comment -%}COL 1: MENU{%- endcomment -%}
          <div class="eafd-col">
            {%- if s.menu_label != blank -%}
              <p class="eafd-col-heading">{{ s.menu_label }}</p>
            {%- endif -%}
            {%- if s.menu != blank -%}
              <ul class="eafd-col-list">
                {%- for link in linklists[s.menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          {%- comment -%}COL 2: COLLECTIONS{%- endcomment -%}
          <div class="eafd-col">
            {%- if s.collections_label != blank -%}
              <p class="eafd-col-heading">{{ s.collections_label }}</p>
            {%- endif -%}
            {%- if s.collections_menu != blank -%}
              <ul class="eafd-col-list">
                {%- for link in linklists[s.collections_menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          {%- comment -%}COL 3: CONTACT{%- endcomment -%}
          <div class="eafd-col">
            {%- if s.contact_label != blank -%}
              <p class="eafd-col-heading">{{ s.contact_label }}</p>
            {%- endif -%}
            <ul class="eafd-col-list">
              {%- if s.contact_phone != blank -%}
                {%- assign phone_clean = s.contact_phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' -%}
                <li><a href="tel:{{ phone_clean }}">{{ s.contact_phone }}</a></li>
              {%- endif -%}
              {%- if s.contact_email != blank -%}
                <li><a href="mailto:{{ s.contact_email }}">{{ s.contact_email }}</a></li>
              {%- endif -%}
              {%- if s.contact_city != blank -%}
                <li><span>{{ s.contact_city }}</span></li>
              {%- endif -%}
              {%- for block in contact_blocks -%}
                {%- if block.settings.text != blank -%}
                  <li>
                    {%- if block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
                    {%- else -%}
                      <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
                    {%- endif -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>

        </div>{%- comment -%}end .eafd-nav{%- endcomment -%}

        {%- comment -%}BOTTOM BAR{%- endcomment -%}
        <div class="eafd-bottom">

          {%- comment -%}SOCIAL ICONS — tutti via blocchi{%- endcomment -%}
          {%- if social_blocks.size > 0 -%}
          <div class="eafd-socials">
            {%- for block in social_blocks -%}
              {%- if block.settings.url != blank -%}
                {%- assign _plt = block.settings.platform -%}
                <a href="{{ block.settings.url }}"
                   class="eafd-social-link"
                   aria-label="{{ _plt | capitalize }}"
                   target="_blank"
                   rel="noopener noreferrer"
                   {{ block.shopify_attributes }}>
                  {%- case _plt -%}
                    {%- when 'instagram' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    {%- when 'facebook' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
