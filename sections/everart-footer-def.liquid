                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.5 12.068c0-3.806 1.26-6.953 3.646-9.09C7.394.906 10.5.06 14.271.045h.023c2.648 0 5.37.58 7.498 2.585 1.98 1.863 2.95 4.5 2.879 7.841-.096 4.441-2.619 7.031-6.95 7.101-1.408.02-2.543-.326-3.296-.98a3.2 3.2 0 01-.42-.463 3.6 3.6 0 01-3.286 2.254c-1.944 0-3.714-1.497-3.714-4.108 0-2.782 1.802-4.517 4.703-4.517.747 0 1.505.096 2.254.284l-.001-.297c-.014-1.34-.518-2.007-1.594-2.007-.685 0-1.253.27-1.651.78l-.031.043-2.09-.563.022-.054c.57-1.395 2.01-2.224 3.85-2.224 2.519 0 3.913 1.364 3.926 3.841l.009 2.152c.01 1.944.393 2.785 1.364 2.785 1.466 0 2.37-1.454 2.37-3.791 0-2.69-.777-4.73-2.247-5.9-1.302-1.035-3.022-1.558-5.115-1.555-3.17.014-5.63.748-7.316 2.182C5.232 7.5 4.5 9.786 4.5 12.068c0 2.967.67 5.305 1.994 6.95 1.406 1.747 3.57 2.65 6.43 2.684 1.22.007 2.505-.156 3.549-.454l.245-.071.483 1.896-.22.07c-1.244.384-2.717.582-4.194.582l-.6-.745zm-.03-10.765c-1.455 0-2.267.766-2.267 2.102 0 1.218.74 1.959 1.929 1.959.935 0 1.695-.485 2.099-1.333l.007-.015-.047-2.366a7.8 7.8 0 00-1.721-.347z"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>
                  {%- endcase -%}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- endif -%}

          {%- comment -%}Copyright{%- endcomment -%}
          {%- if s.copyright_text != blank -%}
            <p class="eafd-legal-text">{{ s.copyright_text }}</p>
          {%- endif -%}

          {%- comment -%}Privacy (setting fisso){%- endcomment -%}
          {%- if s.privacy_text != blank -%}
            {%- if s.privacy_url != blank -%}
              <a href="{{ s.privacy_url }}" class="eafd-legal-text">{{ s.privacy_text }}</a>
            {%- else -%}
              <span class="eafd-legal-text">{{ s.privacy_text }}</span>
            {%- endif -%}
          {%- endif -%}

          {%- comment -%}Terms (setting fisso){%- endcomment -%}
          {%- if s.terms_text != blank -%}
            {%- if s.terms_url != blank -%}
              <a href="{{ s.terms_url }}" class="eafd-legal-text">{{ s.terms_text }}</a>
            {%- else -%}
              <span class="eafd-legal-text">{{ s.terms_text }}</span>
            {%- endif -%}
          {%- endif -%}

          {%- comment -%}Link aggiuntivi dalla barra in basso (blocchi "legal_link"){%- endcomment -%}
          {%- for block in legal_blocks -%}
            {%- if block.settings.label != blank -%}
              {%- if block.settings.url != blank -%}
                <a href="{{ block.settings.url }}" class="eafd-legal-text" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
              {%- else -%}
                <span class="eafd-legal-text" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

        </div>{%- comment -%}end .eafd-bottom{%- endcomment -%}

      </div>{%- comment -%}end .eafd-content{%- endcomment -%}

      {%- comment -%}— DESKTOP LOGO (right) —{%- endcomment -%}
      {%- if has_logo -%}
      <div class="eafd-logo-desktop" id="eafd-logo-desktop-{{ sid }}">
        <img
          src="{{ s.logo | image_url: width: 700 }}"
          alt="{{ shop.name }}"
          loading="lazy"
          width="{{ s.logo.width }}"
          height="{{ s.logo.height }}"
          id="eafd-logo-desktop-img-{{ sid }}"
        >
      </div>
      {%- endif -%}

    </div>{%- comment -%}end .eafd-inner{%- endcomment -%}

  </div>{%- comment -%}end .eafd-card{%- endcomment -%}

</div>{%- comment -%}end #ea-footer-def-{{ sid }}{%- endcomment -%}

<script>
(function () {
  'use strict';

  var SID      = {{ sid | json }};
  var BEHAVIOR = {{ logo_behavior | json }};
  var SCALE    = {{ logo_overflow_scale }};

  var outer = null, card = null;
  var logoDesktop = null, logoDesktopImg = null;
  var logoMobile  = null, logoMobileImg  = null;

  function queryEls() {
    outer          = document.getElementById('ea-footer-def-' + SID);
    card           = document.getElementById('eafd-card-' + SID);
    logoDesktop    = document.getElementById('eafd-logo-desktop-' + SID);
    logoDesktopImg = logoDesktop ? document.getElementById('eafd-logo-desktop-img-' + SID) : null;
    logoMobile     = document.getElementById('eafd-logo-mobile-' + SID);
    logoMobileImg  = logoMobile ? logoMobile.querySelector('img') : null;
  }

  function reset() {
    if (!outer) return;
    outer.style.paddingTop    = '';
    outer.style.paddingBottom = '';
    if (logoMobile)     { logoMobile.style.marginTop = ''; }
    if (logoDesktopImg) { logoDesktopImg.style.height = ''; logoDesktopImg.style.width = ''; }
  }

  function update() {
    if (!outer || !card) return;
    reset();

    var isMobile = window.innerWidth < 768;

    /* ── MOBILE: overflow upward only ────────────────────── */
    if (isMobile) {
      if (!logoMobile || !logoMobileImg || BEHAVIOR !== 'overflow') return;
      var mobileH = logoMobile.offsetHeight;
      if (mobileH <= 0) return;
      var upward = Math.round(mobileH * (1 - 1 / SCALE));
      if (upward <= 0) return;
      logoMobile.style.marginTop = '-' + upward + 'px';
      outer.style.paddingTop     = upward + 'px';
      return;
    }

    /* ── DESKTOP: overflow above + below equally ─────────── */
    if (BEHAVIOR !== 'overflow') return;
    if (!logoDesktop || !logoDesktopImg) return;

    var cardH = card.offsetHeight;
    if (cardH <= 0) return;

    var natW    = logoDesktopImg.naturalWidth  || 307;
    var natH    = logoDesktopImg.naturalHeight || 456;
    var targetH = Math.round(cardH * SCALE);
    var targetW = Math.round(targetH * (natW / natH));

    logoDesktopImg.style.height = targetH + 'px';
    logoDesktopImg.style.width  = targetW + 'px';

    var overflow = Math.round((targetH - cardH) / 2);
    if (overflow > 0) {
      outer.style.paddingTop    = overflow + 'px';
      outer.style.paddingBottom = overflow + 'px';
    }
  }

  function init() {
    queryEls();
    if (!outer || !card) return;

    var imgs = outer.querySelectorAll('img');
    var total = imgs.length, loaded = 0;

    function onLoad() { if (++loaded >= total) update(); }

    if (total === 0) { update(); return; }
    imgs.forEach(function (img) {
      if (img.complete && img.naturalWidth > 0) { onLoad(); }
      else {
        img.addEventListener('load',  onLoad);
        img.addEventListener('error', onLoad);
      }
    });
    update();
  }

  var raf;
  window.addEventListener('resize', function () {
    cancelAnimationFrame(raf);
    raf = requestAnimationFrame(update);
  });

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === SID) { setTimeout(init, 80); }
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
}());
</script>

