{%- comment -%}
  EverArt Footer — v4 (fedele al preview HTML)
  Layout: 4 colonne (2fr 1fr 1fr 1fr) + bottom bar
{%- endcomment -%}

{%- liquid
  assign s   = section.settings
  assign sid = section.id
-%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');

#eafoot-{{ sid }} {
  background: #212121;
  border-top: 1px solid #2a2a2a;
  padding: 80px 48px 36px;
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  box-sizing: border-box;
}

/* ── GRID ── */
#eafoot-{{ sid }} .ef-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 56px;
  margin-bottom: 64px;
}

/* ── COL 1: brand ── */
#eafoot-{{ sid }} .ef-logo img {
  height: 32px;
  display: block;
}
#eafoot-{{ sid }} .ef-tagline {
  font-size: 13px;
  color: #888888;
  line-height: 1.8;
  max-width: 260px;
  margin-top: 16px;
  font-weight: 400;
}
#eafoot-{{ sid }} .ef-claim {
  font-size: 11px;
  color: #666666;
  margin-top: 16px;
  letter-spacing: .08em;
  font-style: italic;
}
#eafoot-{{ sid }} .ef-social {
  display: flex;
  gap: 16px;
  margin-top: 24px;
}
#eafoot-{{ sid }} .ef-social a {
  color: #888888;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: .1em;
  text-transform: uppercase;
  text-decoration: none;
  transition: color .2s;
}
#eafoot-{{ sid }} .ef-social a:hover { color: #ffffff; }

/* ── COLS 2-4: menu ── */
#eafoot-{{ sid }} .ef-col-title {
  font-size: 10px;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: #ffffff;
  margin-bottom: 20px;
  display: block;
  font-weight: 700;
}
#eafoot-{{ sid }} .ef-col ul {
  list-style: none;
  margin: 0;
  padding: 0;
}
#eafoot-{{ sid }} .ef-col ul li {
  margin-bottom: 12px;
}
#eafoot-{{ sid }} .ef-col ul li a,
#eafoot-{{ sid }} .ef-col ul li span {
  font-size: 13px;
  color: #888888;
  font-weight: 400;
  text-decoration: none;
  transition: color .2s;
}
#eafoot-{{ sid }} .ef-col ul li a:hover { color: #ffffff; }

/* ── BOTTOM BAR ── */
#eafoot-{{ sid }} .ef-bot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 36px;
  border-top: 1px solid #2a2a2a;
}
#eafoot-{{ sid }} .ef-bot p {
  font-size: 11px;
  color: #888888;
  letter-spacing: .06em;
  font-weight: 400;
  margin: 0;
}
#eafoot-{{ sid }} .ef-bot a {
  color: #888888;
  text-decoration: none;
  transition: color .2s;
}
#eafoot-{{ sid }} .ef-bot a:hover { color: #ffffff; }

/* ── TABLET ── */
@media (max-width: 989px) {
  #eafoot-{{ sid }} .ef-grid {
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  #eafoot-{{ sid }} .ef-bot {
    flex-direction: column;
    gap: 12px;
    text-align: center;
  }
}

/* ── MOBILE ── */
@media (max-width: 479px) {
  #eafoot-{{ sid }} {
    padding: 60px 24px 28px;
  }
  #eafoot-{{ sid }} .ef-grid {
    grid-template-columns: 1fr;
    gap: 36px;
  }
}
</style>

<footer id="eafoot-{{ sid }}">

  <div class="ef-grid">

    {%- comment -%} COL 1 — Brand {%- endcomment -%}
    <div class="ef-brand">
      {%- if s.logo != blank -%}
        <div class="ef-logo">
          {{- s.logo | image_url: width: 200 | image_tag: alt: s.logo.alt | default: shop.name -}}
        </div>
      {%- endif -%}
      {%- if s.tagline != blank -%}
        <div class="ef-tagline">{{ s.tagline }}</div>
      {%- endif -%}
      {%- if s.claim != blank -%}
        <div class="ef-claim">{{ s.claim }}</div>
      {%- endif -%}
      <div class="ef-social">
        {%- if s.instagram_url != blank -%}
          <a href="{{ s.instagram_url }}" target="_blank" rel="noopener">Instagram</a>
        {%- endif -%}
        {%- if s.facebook_url != blank -%}
          <a href="{{ s.facebook_url }}" target="_blank" rel="noopener">Facebook</a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} COL 2 — Menu principale {%- endcomment -%}
    <div class="ef-col">
      <span class="ef-col-title">{{ s.menu1_title | default: 'Menu' }}</span>
      {%- if s.menu1 != blank -%}
        <ul>
          {%- for link in linklists[s.menu1].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- comment -%} COL 3 — Collections {%- endcomment -%}
    <div class="ef-col">
      <span class="ef-col-title">{{ s.menu2_title | default: 'Collections' }}</span>
      {%- if s.menu2 != blank -%}
        <ul>
          {%- for link in linklists[s.menu2].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- comment -%} COL 4 — Contact {%- endcomment -%}
    <div class="ef-col">
      <span class="ef-col-title">{{ s.contact_title | default: 'Contact' }}</span>
      <ul>
        {%- if s.contact_email != blank -%}
          <li><a href="mailto:{{ s.contact_email }}">{{ s.contact_email }}</a></li>
        {%- endif -%}
        {%- if s.contact_address != blank -%}
          <li><span>{{ s.contact_address }}</span></li>
        {%- endif -%}
        {%- if s.contact_city != blank -%}
          <li><span>{{ s.contact_city }}</span></li>
        {%- endif -%}
        {%- if s.contact_country != blank -%}
          <li><span>{{ s.contact_country }}</span></li>
        {%- endif -%}
      </ul>
    </div>

  </div>

  {%- comment -%} BOTTOM BAR {%- endcomment -%}
  <div class="ef-bot">
    <p>{{ s.copyright | default: 'Everart Studio — All rights reserved · 2026' }}</p>
    <p>
      {%- if s.privacy_url != blank -%}
        <a href="{{ s.privacy_url }}">Privacy</a> &nbsp;·&nbsp;
      {%- endif -%}
      {%- if s.terms_url != blank -%}
        <a href="{{ s.terms_url }}">Terms &amp; Services</a> &nbsp;·&nbsp;
      {%- endif -%}
      {%- if s.returns_url != blank -%}
        <a href="{{ s.returns_url }}">Returns &amp; Refund</a>
      {%- endif -%}
    </p>
  </div>

</footer>

{% schema %}
{
  "name": "EverArt Footer",
  "class": "section-wrapper",
  "enabled_on": { "groups": ["footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "We don't make statues.\nWe make stories."
    },
    {
      "type": "text",
      "id": "claim",
      "label": "Claim (italic)",
      "default": "\"Once gone, it's forever.\""
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "header",
      "content": "Menu 1"
    },
    {
      "type": "text",
      "id": "menu1_title",
      "label": "Titolo colonna",
      "default": "Menu"
    },
    {
      "type": "link_list",
      "id": "menu1",
      "label": "Menu principale",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Menu 2"
    },
    {
      "type": "text",
      "id": "menu2_title",
      "label": "Titolo colonna",
      "default": "Collections"
    },
    {
      "type": "link_list",
      "id": "menu2",
      "label": "Menu collezioni"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Titolo colonna",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "info@studioeverart.com"
    },
    {
      "type": "text",
      "id": "contact_address",
      "label": "Indirizzo",
      "default": "Via Carlo Pisacane 28"
    },
    {
      "type": "text",
      "id": "contact_city",
      "label": "CAP e città",
      "default": "81030 — Parete (CE)"
    },
    {
      "type": "text",
      "id": "contact_country",
      "label": "Paese",
      "default": "Italy"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Testo copyright",
      "default": "Everart Studio — All rights reserved · 2026"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "URL Privacy"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "URL Terms & Services"
    },
    {
      "type": "url",
      "id": "returns_url",
      "label": "URL Returns & Refund"
    }
  ]
}
{% endschema %}
