{%- comment -%}
  EverArt Product Suggestions — v2
  Prodotti dalla stessa collection del prodotto corrente (escluso sé stesso).
  Layout: flex centrato · card fissa 25% desktop · 2 col mobile
{%- endcomment -%}

{%- assign s   = section.settings -%}
{%- assign sid = section.id -%}
{%- assign coll = product.collections | first -%}

{%- comment -%} Raccoglie i prodotti correlati (stessa collection, escluso il corrente) {%- endcomment -%}
{%- assign shown = 0 -%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,300;0,400;0,600;0,700&display=swap');

#eps-{{ sid }} {
  background: #0a0a0a;
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  padding: 80px 0 96px;
}

/* ── Header ── */
#eps-{{ sid }} .eps-head {
  padding: 0 48px;
  max-width: 1300px;
  margin: 0 auto 48px;
}
#eps-{{ sid }} .eps-eyebrow {
  font-size: 10px;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: #888888;
  font-weight: 500;
  margin: 0 0 14px;
  display: block;
}
#eps-{{ sid }} .eps-title {
  font-size: clamp(26px, 3vw, 38px);
  font-weight: 700;
  letter-spacing: -.02em;
  line-height: 1.05;
  color: #ffffff;
  margin: 0;
}

/* ── Grid ── */
#eps-{{ sid }} .eps-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1px;
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 48px;
  box-sizing: border-box;
}

/* ── Card ── */
#eps-{{ sid }} .eps-card {
  flex: 0 0 calc(25% - 1px);
  background: #0a0a0a;
  cursor: pointer;
  text-decoration: none;
  color: inherit;
  display: block;
  transition: background .2s;
  border: 1px solid #2a2a2a;
}
#eps-{{ sid }} .eps-card:hover { background: #0f0f0f; }

/* Immagine con hover */
#eps-{{ sid }} .eps-img-wrap {
  aspect-ratio: 4/5;
  position: relative;
  overflow: hidden;
  background: #212121;
}
#eps-{{ sid }} .eps-img-1,
#eps-{{ sid }} .eps-img-2 {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity .4s ease;
}
#eps-{{ sid }} .eps-img-2 { opacity: 0; }
#eps-{{ sid }} .eps-card:hover .eps-img-1 { opacity: 0; }
#eps-{{ sid }} .eps-card:hover .eps-img-2 { opacity: 1; }

/* Body */
#eps-{{ sid }} .eps-body {
  padding: 20px 22px 28px;
  border-top: 1px solid #2a2a2a;
}
#eps-{{ sid }} .eps-name {
  font-size: 13px;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.35;
  letter-spacing: -.01em;
  margin: 0 0 8px;
}
#eps-{{ sid }} .eps-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 8px;
}
#eps-{{ sid }} .eps-price {
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -.02em;
}
#eps-{{ sid }} .eps-price-compare {
  font-size: 13px;
  font-weight: 300;
  color: #ffffff;
  opacity: 0.5;
  letter-spacing: -.01em;
  text-decoration: line-through;
}

/* ── Mobile ── */
@media (max-width: 767px) {
  #eps-{{ sid }} { padding: 60px 0 72px; }
  #eps-{{ sid }} .eps-head { padding: 0 24px; margin-bottom: 36px; }
  #eps-{{ sid }} .eps-grid { padding: 0 24px; }
  #eps-{{ sid }} .eps-card { flex: 0 0 calc(50% - 1px); }
}
@media (min-width: 768px) and (max-width: 1023px) {
  #eps-{{ sid }} .eps-card { flex: 0 0 calc(33.333% - 1px); }
}
</style>

{%- if coll != blank -%}
  {%- assign has_related = false -%}
  {%- for p in coll.products -%}
    {%- unless p.id == product.id -%}
      {%- assign has_related = true -%}
      {%- break -%}
    {%- endunless -%}
  {%- endfor -%}

  {%- if has_related -%}
    <div id="eps-{{ sid }}">
      <div class="eps-head">
        {%- if s.eyebrow != blank -%}
          <span class="eps-eyebrow">{{ s.eyebrow }}</span>
        {%- endif -%}
        <h2 class="eps-title">
          {%- case localization.language.iso_code -%}
            {%- when 'it' -%}Potrebbe interessarti anche
            {%- when 'fr' -%}Vous aimerez peut-être aussi
            {%- when 'de' -%}Das könnte dir auch gefallen
            {%- when 'es' -%}También te puede gustar
            {%- else -%}You may also like
          {%- endcase -%}
        </h2>
      </div>

      <div class="eps-grid">
        {%- assign shown = 0 -%}
        {%- for p in coll.products -%}
          {%- if p.id == product.id -%}{%- continue -%}{%- endif -%}
          {%- if shown >= s.limit -%}{%- break -%}{%- endif -%}
          <a class="eps-card" href="{{ p.url }}">
            <div class="eps-img-wrap">
              {%- if p.featured_image != blank -%}
                <img class="eps-img-1"
                     src="{{ p.featured_image | image_url: width: 800 }}"
                     loading="lazy"
                     alt="{{ p.featured_image.alt | default: p.title }}"
                     width="800">
              {%- endif -%}
              {%- if p.images.size > 1 -%}
                <img class="eps-img-2"
                     src="{{ p.images[1] | image_url: width: 800 }}"
                     loading="lazy"
                     alt="{{ p.images[1].alt | default: p.title }}"
                     width="800">
              {%- endif -%}
            </div>
            <div class="eps-body">
              <p class="eps-name">{{ p.title }}</p>
              <div class="eps-price-wrap">
                <span class="eps-price">{{ p.variants.first.price | money }}</span>
                {%- if p.variants.first.compare_at_price > p.variants.first.price -%}
                  <span class="eps-price-compare">{{ p.variants.first.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </a>
          {%- assign shown = shown | plus: 1 -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Prodotti suggeriti",
  "tag": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Numero prodotti",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Prodotti suggeriti"
    }
  ]
}
{% endschema %}
