{%- comment -%}
  EverArt Product Suggestions — v1
  • Carica i prodotti suggeriti via Shopify Recommendations API (async)
  • Card identiche a everart-latest-treasures (hover immagine, prezzo barrato)
  • Layout: griglia 4 colonne desktop · 2 mobile
{%- endcomment -%}

{%- assign s   = section.settings -%}
{%- assign sid = section.id -%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,300;0,400;0,600;0,700&display=swap');

#eps-{{ sid }} {
  background: #0a0a0a;
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
  padding: 80px 0 96px;
}

/* ── Header ── */
#eps-{{ sid }} .eps-head {
  padding: 0 48px;
  max-width: 1200px;
  margin: 0 auto 48px;
}
#eps-{{ sid }} .eps-eyebrow {
  font-size: 10px;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: #888888;
  font-weight: 500;
  margin: 0 0 14px;
  display: block;
}
#eps-{{ sid }} .eps-title {
  font-size: clamp(26px, 3vw, 38px);
  font-weight: 700;
  letter-spacing: -.02em;
  line-height: 1.05;
  color: #ffffff;
  margin: 0;
}

/* ── Grid ── */
#eps-{{ sid }} .eps-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: #2a2a2a;
}

/* ── Card ── */
#eps-{{ sid }} .eps-card {
  background: #0a0a0a;
  cursor: pointer;
  text-decoration: none;
  color: inherit;
  display: block;
  transition: background .2s;
}
#eps-{{ sid }} .eps-card:hover { background: #0f0f0f; }

/* Immagine con hover */
#eps-{{ sid }} .eps-img-wrap {
  aspect-ratio: 4/5;
  position: relative;
  overflow: hidden;
  background: #212121;
}
#eps-{{ sid }} .eps-img-1,
#eps-{{ sid }} .eps-img-2 {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity .4s ease;
}
#eps-{{ sid }} .eps-img-2 { opacity: 0; }
#eps-{{ sid }} .eps-card:hover .eps-img-1 { opacity: 0; }
#eps-{{ sid }} .eps-card:hover .eps-img-2 { opacity: 1; }

/* Body */
#eps-{{ sid }} .eps-body {
  padding: 20px 22px 28px;
  border-top: 1px solid #2a2a2a;
}
#eps-{{ sid }} .eps-name {
  font-size: 13px;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.35;
  letter-spacing: -.01em;
  margin: 0 0 8px;
}
#eps-{{ sid }} .eps-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 8px;
}
#eps-{{ sid }} .eps-price {
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -.02em;
}
#eps-{{ sid }} .eps-price-compare {
  font-size: 13px;
  font-weight: 300;
  color: #ffffff;
  opacity: 0.5;
  letter-spacing: -.01em;
  text-decoration: line-through;
}

/* ── Mobile ── */
@media (max-width: 767px) {
  #eps-{{ sid }} { padding: 60px 0 72px; }
  #eps-{{ sid }} .eps-head { padding: 0 24px; margin-bottom: 36px; }
  #eps-{{ sid }} .eps-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 768px) and (max-width: 1023px) {
  #eps-{{ sid }} .eps-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>

<div id="eps-{{ sid }}"
     data-section-id="{{ sid }}"
     data-product-id="{{ product.id }}"
     data-limit="{{ s.limit }}">

  {%- if recommendations.performed? and recommendations.products_count > 0 -%}

    <div class="eps-head">
      {%- if s.eyebrow != blank -%}
        <span class="eps-eyebrow">{{ s.eyebrow }}</span>
      {%- endif -%}
      {%- if s.heading != blank -%}
        <h2 class="eps-title">{{ s.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="eps-grid">
      {%- for p in recommendations.products -%}
        <a class="eps-card" href="{{ p.url }}">
          <div class="eps-img-wrap">
            {%- if p.featured_image != blank -%}
              <img class="eps-img-1"
                   src="{{ p.featured_image | image_url: width: 800 }}"
                   loading="lazy"
                   alt="{{ p.featured_image.alt | default: p.title }}"
                   width="800">
            {%- endif -%}
            {%- if p.images.size > 1 -%}
              <img class="eps-img-2"
                   src="{{ p.images[1] | image_url: width: 800 }}"
                   loading="lazy"
                   alt="{{ p.images[1].alt | default: p.title }}"
                   width="800">
            {%- endif -%}
          </div>
          <div class="eps-body">
            <p class="eps-name">{{ p.title }}</p>
            <div class="eps-price-wrap">
              <span class="eps-price">{{ p.price | money }}</span>
              {%- if p.compare_at_price > p.price -%}
                <span class="eps-price-compare">{{ p.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

  {%- endif -%}
</div>

<script>
(function() {
  var wrap = document.getElementById('eps-{{ sid }}');
  if (!wrap || wrap.querySelector('.eps-grid')) return;

  var productId = wrap.dataset.productId;
  var sectionId = wrap.dataset.sectionId;
  var limit     = wrap.dataset.limit || '4';
  if (!productId) return;

  // Il contenuto arriva dal nostro storefront Shopify (stesso origin)
  fetch('/recommendations/products?section_id=' + sectionId + '&product_id=' + productId + '&limit=' + limit)
    .then(function(r) { return r.text(); })
    .then(function(html) {
      var parser  = new DOMParser();
      var doc     = parser.parseFromString(html, 'text/html');
      var newWrap = doc.getElementById('eps-' + sectionId);
      if (newWrap) wrap.replaceWith(newWrap);
    })
    .catch(function() {});
})();
</script>

{% schema %}
{
  "name": "Prodotti suggeriti",
  "tag": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "You might also like"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Numero prodotti",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Prodotti suggeriti"
    }
  ]
}
{% endschema %}
