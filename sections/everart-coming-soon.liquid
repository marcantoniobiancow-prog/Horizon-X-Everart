{%- comment -%}
  EverArt Coming Soon — v1
  Sezione homepage: header + 2 card grandi (Frankenstein + Dracula)
  Ogni card: immagine di sfondo, overlay, tag, titolo, sottotitolo, CTA button
{%- endcomment -%}

{%- liquid
  assign s   = section.settings
  assign sid = section.id
-%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');

#eacs-{{ sid }} {
  background: #0a0a0a;
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
}

/* ── HEADER ── */
#eacs-{{ sid }} .ecs-head {
  padding: 80px 48px 72px;
  max-width: 1200px;
  margin: 0 auto;
}
#eacs-{{ sid }} .ecs-eyebrow {
  font-size: 10px;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: #888888;
  font-weight: 500;
  margin: 0 0 14px;
}
#eacs-{{ sid }} .ecs-title {
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  letter-spacing: -.02em;
  line-height: 1.05;
  color: #ffffff;
  margin: 0 0 16px;
}
#eacs-{{ sid }} .ecs-desc {
  font-size: 14px;
  color: #888888;
  line-height: 1.75;
  max-width: 480px;
  margin: 0;
  font-weight: 400;
}

/* ── GRID ── */
#eacs-{{ sid }} .ecs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: #2a2a2a;
}

/* ── CARD ── */
#eacs-{{ sid }} .ecs-card {
  position: relative;
  min-height: 480px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
  background: #212121;
  text-decoration: none;
  color: inherit;
}
#eacs-{{ sid }} .ecs-card-img {
  position: absolute;
  inset: 0;
  z-index: 0;
}
#eacs-{{ sid }} .ecs-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
#eacs-{{ sid }} .ecs-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(5,5,5,.97) 0%, rgba(5,5,5,.4) 55%, transparent 100%);
  z-index: 1;
}
#eacs-{{ sid }} .ecs-body {
  position: relative;
  z-index: 2;
  padding: 48px 56px;
}
#eacs-{{ sid }} .ecs-tag {
  display: inline-block;
  border: 1px solid #8b1a1a;
  color: #8b1a1a;
  font-size: 9px;
  letter-spacing: .24em;
  text-transform: uppercase;
  padding: 4px 12px;
  margin-bottom: 16px;
  font-weight: 600;
}
#eacs-{{ sid }} .ecs-name {
  font-size: 40px;
  line-height: 1.0;
  font-weight: 700;
  letter-spacing: -.02em;
  margin: 0 0 8px;
  color: #ffffff;
}
#eacs-{{ sid }} .ecs-sub {
  font-size: 13px;
  color: #888888;
  margin: 0 0 28px;
  font-weight: 400;
  font-style: italic;
}
#eacs-{{ sid }} .ecs-btn {
  display: inline-block;
  background: #8b1a1a;
  color: #ffffff;
  border: none;
  padding: 12px 28px;
  font-size: 9px;
  letter-spacing: .22em;
  text-transform: uppercase;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Instrument Sans', sans-serif;
  text-decoration: none;
  transition: background .2s;
}
#eacs-{{ sid }} .ecs-btn:hover { background: #a52020; }

/* ── RESPONSIVE ── */
@media (max-width: 767px) {
  #eacs-{{ sid }} .ecs-head { padding: 60px 24px 48px; }
  #eacs-{{ sid }} .ecs-grid { grid-template-columns: 1fr; }
  #eacs-{{ sid }} .ecs-card { min-height: 380px; }
  #eacs-{{ sid }} .ecs-body { padding: 32px 28px; }
  #eacs-{{ sid }} .ecs-name { font-size: 28px; }
}
</style>

<div id="eacs-{{ sid }}">

  {%- comment -%} ── HEADER ── {%- endcomment -%}
  <div class="ecs-head">
    {%- if s.eyebrow != blank -%}
      <p class="ecs-eyebrow">{{ s.eyebrow }}</p>
    {%- endif -%}
    {%- if s.heading != blank -%}
      <h2 class="ecs-title">{{ s.heading }}</h2>
    {%- endif -%}
    {%- if s.description != blank -%}
      <p class="ecs-desc">{{ s.description }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} ── CARDS ── {%- endcomment -%}
  <div class="ecs-grid">

    {%- for i in (1..2) -%}
      {%- if i == 1 -%}
        {%- assign card_image   = s.card1_image -%}
        {%- assign card_tag     = s.card1_tag -%}
        {%- assign card_name    = s.card1_name -%}
        {%- assign card_sub     = s.card1_sub -%}
        {%- assign card_btn     = s.card1_btn -%}
        {%- assign card_url     = s.card1_url -%}
      {%- else -%}
        {%- assign card_image   = s.card2_image -%}
        {%- assign card_tag     = s.card2_tag -%}
        {%- assign card_name    = s.card2_name -%}
        {%- assign card_sub     = s.card2_sub -%}
        {%- assign card_btn     = s.card2_btn -%}
        {%- assign card_url     = s.card2_url -%}
      {%- endif -%}

      <div class="ecs-card">
        <div class="ecs-card-img">
          {%- if card_image != blank -%}
            {{ card_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: card_name }}
          {%- endif -%}
        </div>
        <div class="ecs-overlay"></div>
        <div class="ecs-body">
          {%- if card_tag != blank -%}
            <span class="ecs-tag">{{ card_tag }}</span>
          {%- endif -%}
          {%- if card_name != blank -%}
            <h3 class="ecs-name">{{ card_name }}</h3>
          {%- endif -%}
          {%- if card_sub != blank -%}
            <p class="ecs-sub">{{ card_sub }}</p>
          {%- endif -%}
          {%- if card_btn != blank -%}
            <a class="ecs-btn" href="{{ card_url | default: '#' }}">{{ card_btn }}</a>
          {%- endif -%}
        </div>
      </div>

    {%- endfor -%}

  </div>

</div>

{% schema %}
{
  "name": "Coming Soon",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Header sezione"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Masters of Madness — Next Chapters"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "The collection\ncontinues."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descrizione",
      "default": "Two masters await. Be the first to know — and secure your place before the public announcement."
    },
    {
      "type": "header",
      "content": "Card 1 — Frankenstein"
    },
    {
      "type": "image_picker",
      "id": "card1_image",
      "label": "Immagine di sfondo"
    },
    {
      "type": "text",
      "id": "card1_tag",
      "label": "Tag",
      "default": "Masters of Madness — Chapter II"
    },
    {
      "type": "text",
      "id": "card1_name",
      "label": "Titolo",
      "default": "Frankenstein\nby Mary Shelley"
    },
    {
      "type": "text",
      "id": "card1_sub",
      "label": "Sottotitolo (italic)",
      "default": "The creature meets its creator."
    },
    {
      "type": "text",
      "id": "card1_btn",
      "label": "Testo bottone",
      "default": "Discover Chapter II"
    },
    {
      "type": "url",
      "id": "card1_url",
      "label": "Link bottone"
    },
    {
      "type": "header",
      "content": "Card 2 — Dracula"
    },
    {
      "type": "image_picker",
      "id": "card2_image",
      "label": "Immagine di sfondo"
    },
    {
      "type": "text",
      "id": "card2_tag",
      "label": "Tag",
      "default": "Masters of Madness — Chapter III"
    },
    {
      "type": "text",
      "id": "card2_name",
      "label": "Titolo",
      "default": "Dracula\nby Bram Stoker"
    },
    {
      "type": "text",
      "id": "card2_sub",
      "label": "Sottotitolo (italic)",
      "default": "Immortality has a price."
    },
    {
      "type": "text",
      "id": "card2_btn",
      "label": "Testo bottone",
      "default": "Discover Chapter III"
    },
    {
      "type": "url",
      "id": "card2_url",
      "label": "Link bottone"
    }
  ]
}
{% endschema %}
