{%- comment -%}
  EverArt Product Video — v1
  Unboxing video + 3 info cells
{%- endcomment -%}

{%- assign s   = section.settings -%}
{%- assign sid = section.id -%}

<style>
#epv-{{ sid }} {
  padding: 96px 0;
  background: #0a0a0a;
  border-top: 1px solid #2a2a2a;
  font-family: 'Instrument Sans', 'Helvetica Neue', Arial, sans-serif;
}
#epv-{{ sid }} .epv-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 48px;
}
#epv-{{ sid }} .epv-head {
  text-align: center;
  margin-bottom: 52px;
}
#epv-{{ sid }} .epv-label {
  font-size: 9.5px;
  letter-spacing: .26em;
  text-transform: uppercase;
  color: #888888;
  font-weight: 600;
  display: block;
  margin-bottom: 14px;
}
#epv-{{ sid }} .epv-title {
  font-size: clamp(24px, 3vw, 38px);
  font-weight: 700;
  letter-spacing: -.02em;
  color: #ffffff;
  margin: 0 0 12px;
  line-height: 1.1;
}
#epv-{{ sid }} .epv-desc {
  max-width: 520px;
  margin: 0 auto;
  font-size: 14px;
  color: #888888;
  line-height: 1.7;
  font-weight: 400;
}
#epv-{{ sid }} .epv-video-wrap {
  max-width: 860px;
  margin: 0 auto;
}
#epv-{{ sid }} .epv-ratio {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  overflow: hidden;
  background: #121212;
  border: 1px solid #2a2a2a;
}
#epv-{{ sid }} .epv-ratio iframe {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border: 0;
}
#epv-{{ sid }} .epv-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
}
#epv-{{ sid }} .epv-play-icon {
  width: 64px; height: 64px;
  border-radius: 50%;
  background: #8b1a1a;
  display: flex;
  align-items: center;
  justify-content: center;
}
#epv-{{ sid }} .epv-play-label {
  font-size: 10px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: #888888;
}
#epv-{{ sid }} .epv-cells {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: #2a2a2a;
  margin-top: 1px;
}
#epv-{{ sid }} .epv-cell {
  background: #121212;
  padding: 24px;
  text-align: center;
}
#epv-{{ sid }} .epv-cell-label {
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: #888888;
  margin-bottom: 6px;
  font-weight: 500;
}
#epv-{{ sid }} .epv-cell-value {
  font-size: 13px;
  color: #ffffff;
  font-weight: 600;
}
@media (max-width: 767px) {
  #epv-{{ sid }} { padding: 60px 0; }
  #epv-{{ sid }} .epv-inner { padding: 0 20px; }
  #epv-{{ sid }} .epv-cells { grid-template-columns: 1fr; }
}
</style>

<div id="epv-{{ sid }}">
  <div class="epv-inner">
    <div class="epv-head">
      {%- if s.eyebrow != blank -%}<span class="epv-label">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="epv-title">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.description != blank -%}<p class="epv-desc">{{ s.description }}</p>{%- endif -%}
    </div>

    <div class="epv-video-wrap">
      <div class="epv-ratio">
        {%- if s.youtube_url != blank -%}
          <iframe
            src="{{ s.youtube_url }}"
            title="{{ s.heading | default: 'Unboxing Video' }}"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        {%- else -%}
          <div class="epv-placeholder">
            <div class="epv-play-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <polygon points="9,6 20,12 9,18" fill="white"/>
              </svg>
            </div>
            <span class="epv-play-label">Unboxing Video</span>
          </div>
        {%- endif -%}
      </div>

      <div class="epv-cells">
        {%- if s.cell1_label != blank or s.cell1_value != blank -%}
          <div class="epv-cell">
            <div class="epv-cell-label">{{ s.cell1_label }}</div>
            <div class="epv-cell-value">{{ s.cell1_value }}</div>
          </div>
        {%- endif -%}
        {%- if s.cell2_label != blank or s.cell2_value != blank -%}
          <div class="epv-cell">
            <div class="epv-cell-label">{{ s.cell2_label }}</div>
            <div class="epv-cell-value">{{ s.cell2_value }}</div>
          </div>
        {%- endif -%}
        {%- if s.cell3_label != blank or s.cell3_value != blank -%}
          <div class="epv-cell">
            <div class="epv-cell-label">{{ s.cell3_label }}</div>
            <div class="epv-cell-value">{{ s.cell3_value }}</div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Prodotto — Video",
  "tag": "section",
  "templates": ["product"],
  "settings": [
    { "type": "text",     "id": "eyebrow",     "label": "Eyebrow", "default": "Real. Unfiltered." },
    { "type": "text",     "id": "heading",     "label": "Titolo",  "default": "See what arrives at your door." },
    { "type": "textarea", "id": "description", "label": "Descrizione" },
    { "type": "text",     "id": "youtube_url", "label": "YouTube embed URL (https://www.youtube.com/embed/VIDEO_ID)" },
    { "type": "header",   "content": "Celle informative" },
    { "type": "text", "id": "cell1_label", "label": "Cella 1 — label", "default": "Packaging" },
    { "type": "text", "id": "cell1_value", "label": "Cella 1 — valore", "default": "Custom protective box" },
    { "type": "text", "id": "cell2_label", "label": "Cella 2 — label", "default": "Shipping" },
    { "type": "text", "id": "cell2_value", "label": "Cella 2 — valore", "default": "Insured & tracked" },
    { "type": "text", "id": "cell3_label", "label": "Cella 3 — label", "default": "Condition" },
    { "type": "text", "id": "cell3_value", "label": "Cella 3 — valore", "default": "Inspected before dispatch" }
  ],
  "presets": [{ "name": "Prodotto — Video" }]
}
{% endschema %}
